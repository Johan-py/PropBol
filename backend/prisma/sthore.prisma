generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// AUTENTICACIÓN Y USUARIOS
// ─────────────────────────────────────────────

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   RolNombre @unique
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id                               Int       @id @default(autoincrement())
  nombre                           String
  apellido                         String
  correo                           String    @unique
  password                         String
  pais                             String?
  avatar                           String?
  genero                           Genero?
  direccion                        String?
  activo                           Boolean   @default(true)
  notificacion_email               Boolean   @default(true)   @map("notificacion_email")
  notificacion_whatsapp            Boolean   @default(false)  @map("notificacion_whatsapp")
  fecha_registro                   DateTime  @default(now())  @map("fecha_registro")
  created_at                       DateTime  @default(now())  @map("created_at")
  updated_at                       DateTime  @updatedAt       @map("updated_at")
  rol_id                           Int       @map("rol_id")

  intentos_fallidos_cambio_password Int      @default(0)      @map("intentos_fallidos_cambio_password")
  bloqueo_cambio_password_hasta     DateTime?                 @map("bloqueo_cambio_password_hasta") @db.Timestamptz(6)
  password_actualizado_en           DateTime  @default(now()) @map("password_actualizado_en")        @db.Timestamptz(6)
  two_factor_activo                 Boolean   @default(false) @map("two_factor_activo")
  two_factor_metodo                 String    @default("email") @map("two_factor_metodo")            @db.VarChar(20)
  two_factor_activado_en            DateTime?                 @map("two_factor_activado_en")         @db.Timestamptz(6)
  desactivado_en                    DateTime?                 @map("desactivado_en")
  controlador                       Boolean   @default(false) @map("controlador")
  fecha_nacimiento                  DateTime?                 @map("fecha_nacimiento")
  telemetria_compartida             Boolean   @default(false) @map("telemetria_compartida")
  zona_conexion                     String?                   @map("zona_conexion")                  @db.VarChar(100)

  autenticacion_social  autenticacion_social[]
  bitacora_pagos        bitacora_pagos[]
  blogs                 Blog[]
  cambio_emails         CambioEmail[]
  codigo_2fa            codigo_2fa[]
  comentarios           Comentario[]
  comparaciones         comparacion[]
  favoritos             favorito[]
  historial_busqueda    historial_busqueda[]
  historial_password    historial_password[]
  inmuebles             Inmueble[]
  likes_comentario      ComentarioLike[]
  notificaciones        Notificacion[]
  perfil                Perfil?
  propiedad_vista       propiedad_vista[]
  publicaciones         Publicacion[]
  recuperacion_password recuperacion_password[]
  sesiones              Sesion[]
  suscripciones_activas suscripciones_activas[]
  telefonos             Telefono[]
  transacciones         transacciones[]
  verificacion_pago     verificacion_pago[]
  visitas               Visitor[]
  zona_usuario          zona_usuario[]

  rol Rol @relation(fields: [rol_id], references: [id])

  @@index([correo])
  @@index([rol_id])
  @@map("usuario")
}

model Sesion {
  id               Int      @id @default(autoincrement())
  token            String   @unique @db.VarChar(512)
  estado           Boolean  @default(true)
  fecha_inicio     DateTime @default(now()) @map("fecha_inicio")
  fecha_expiracion DateTime @map("fecha_expiracion")
  usuario_id       Int      @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("sesion")
}

model autenticacion_social {
  id               Int       @id @default(autoincrement())
  usuario_id       Int       @map("usuario_id")
  proveedor        String    @db.VarChar(30)
  correo_proveedor String?   @db.VarChar(100) @map("correo_proveedor")
  id_externo       String    @db.VarChar(150) @map("id_externo")
  vinculado_en     DateTime? @default(now()) @map("vinculado_en") @db.Timestamptz(6)
  activo           Boolean   @default(true)

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([proveedor, id_externo],   map: "autenticacion_social_proveedor_id_externo_key")
  @@unique([usuario_id, proveedor],   map: "autenticacion_social_usuario_proveedor_key")
  @@index([usuario_id])
  @@map("autenticacion_social")
}

model codigo_2fa {
  id          Int       @id @default(autoincrement())
  usuario_id  Int       @map("usuario_id")
  codigo_hash String    @db.VarChar(255) @map("codigo_hash")
  creado_en   DateTime? @default(now()) @map("creado_en") @db.Timestamptz(6)
  expira_en   DateTime  @map("expira_en")                 @db.Timestamptz(6)
  usado_en    DateTime? @map("usado_en")                  @db.Timestamptz(6)
  intentos    Int       @default(0)
  activo      Boolean   @default(true)

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id, creado_en], map: "codigo_2fa_usuario_fecha_idx")
  @@map("codigo_2fa")
}

model recuperacion_password {
  id         Int       @id @default(autoincrement())
  usuario_id Int       @map("usuario_id")
  token      String    @unique @db.VarChar(255)
  expira_en  DateTime  @map("expira_en")  @db.Timestamptz(6)
  creado_en  DateTime  @default(now()) @map("creado_en") @db.Timestamptz(6)
  usado_en   DateTime? @map("usado_en")   @db.Timestamptz(6)
  intentos   Int       @default(0)
  activo     Boolean   @default(true)

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id, creado_en], map: "recuperacion_password_usuario_fecha_idx")
  @@map("recuperacion_password")
}

model historial_password {
  id            Int      @id @default(autoincrement())
  usuario_id    Int      @map("usuario_id")
  password_hash String   @db.VarChar(255) @map("password_hash")
  creado_en     DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id, creado_en], map: "historial_password_usuario_fecha_idx")
  @@map("historial_password")
}

model CambioEmail {
  id            Int       @id @default(autoincrement())
  email_nuevo   String    @map("email_nuevo")
  token         String    @unique
  expira_en     DateTime  @map("expira_en")
  creado_en     DateTime  @default(now()) @map("creado_en")
  completado_en DateTime? @map("completado_en")
  usuario_id    Int       @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("cambio_email")
}

// ─────────────────────────────────────────────
// PERFIL Y CONTACTO
// ─────────────────────────────────────────────

model Perfil {
  id             Int     @id @default(autoincrement())
  nombre_completo String @map("nombre_completo")
  datos          Json?
  usuario_id     Int     @unique @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@map("perfil")
}

model Telefono {
  id          Int     @id @default(autoincrement())
  codigo_pais String  @map("codigo_pais")
  numero      String
  principal   Boolean @default(false)
  usuario_id  Int     @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("telefono")
}

model Notificacion {
  id             Int       @id @default(autoincrement())
  titulo         String
  mensaje        String
  leida          Boolean   @default(false)
  fecha_creacion DateTime  @default(now()) @map("fecha_creacion")
  fecha_lectura  DateTime? @map("fecha_lectura")
  eliminada      Boolean   @default(false)
  archivada      Boolean   @default(false)
  usuario_id     Int       @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("notificacion")
}

// ─────────────────────────────────────────────
// BLOG
// ─────────────────────────────────────────────

model CategoriaBlog {
  id     Int    @id @default(autoincrement())
  nombre String @unique @db.VarChar(100)

  blogs Blog[]

  @@map("categoria_blog")
}

model Blog {
  id                Int        @id @default(autoincrement())
  titulo            String
  contenido         String
  imagen            String?
  estado            EstadoBlog
  eliminado         Boolean    @default(false)
  fecha_creacion    DateTime   @default(now()) @map("fecha_creacion")
  fecha_publicacion DateTime?  @map("fecha_publicacion")
  usuario_id        Int        @map("usuario_id")
  categoria_id      Int        @map("categoria_id")

  usuario    Usuario       @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  categoria  CategoriaBlog @relation(fields: [categoria_id], references: [id])
  comentarios Comentario[]
  rechazos    BlogRechazo[]

  @@index([estado],      map: "blog_estado_idx")
  @@index([usuario_id],  map: "blog_usuario_idx")
  @@index([categoria_id])
  @@map("blog")
}

model BlogRechazo {
  id         Int      @id @default(autoincrement())
  comentario String
  fecha      DateTime @default(now())
  blog_id    Int      @map("blog_id")

  blog Blog @relation(fields: [blog_id], references: [id], onDelete: Cascade)

  @@index([blog_id])
  @@map("blog_rechazo")
}

model Comentario {
  id                  Int       @id @default(autoincrement())
  contenido           String
  fecha_creacion      DateTime  @default(now()) @map("fecha_creacion")
  usuario_id          Int       @map("usuario_id")
  blog_id             Int       @map("blog_id")
  comentario_padre_id Int?      @map("comentario_padre_id")

  usuario   Usuario     @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  blog      Blog        @relation(fields: [blog_id], references: [id], onDelete: Cascade)
  padre     Comentario? @relation("ComentarioPadre", fields: [comentario_padre_id], references: [id], onDelete: Cascade)
  respuestas Comentario[] @relation("ComentarioPadre")
  likes     ComentarioLike[]

  @@index([blog_id],    map: "comentario_blog_idx")
  @@index([usuario_id])
  @@map("comentario")
}

model ComentarioLike {
  id            Int @id @default(autoincrement())
  usuario_id    Int @map("usuario_id")
  comentario_id Int @map("comentario_id")

  usuario    Usuario    @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  comentario Comentario @relation(fields: [comentario_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, comentario_id], map: "comentario_like_unique")
  @@index([comentario_id])
  @@map("comentario_like")
}

// ─────────────────────────────────────────────
// INMUEBLES
// ─────────────────────────────────────────────

model Inmueble {
  id                Int            @id @default(autoincrement())
  titulo            String
  categoria         Categoria?
  precio            Decimal        @db.Decimal(12, 2)
  superficie_m2     Decimal?       @db.Decimal(10, 2) @map("superficie_m2")
  nro_cuartos       Int?           @map("nro_cuartos")
  nro_banos         Int?           @map("nro_banos")
  descripcion       String?
  estado            EstadoInmueble @default(ACTIVO)
  tipo_accion       TipoAccion     @map("tipo_accion")
  fecha_publicacion DateTime       @default(now()) @map("fecha_publicacion")
  propietario_id    Int            @map("propietario_id")
  created_at        DateTime       @default(now()) @map("created_at")
  updated_at        DateTime       @updatedAt      @map("updated_at")

  propietario  Usuario            @relation(fields: [propietario_id], references: [id], onDelete: Cascade)
  amenidades   InmuebleAmenidad[]
  etiquetas    InmuebleEtiqueta[]
  marcadores   MarcadorMapa[]
  publicaciones Publicacion[]
  ubicacion    UbicacionInmueble?
  vistas       propiedad_vista[]
  comparaciones detalle_comparacion[]
  favoritos    favorito[]

  @@index([propietario_id])
  @@index([estado])
  @@index([tipo_accion])
  @@map("inmueble")
}

model UbicacionInmueble {
  id                  Int      @id @default(autoincrement())
  latitud             Decimal  @db.Decimal(10, 7)
  longitud            Decimal  @db.Decimal(10, 7)
  direccion           String?
  ciudad              String?
  zona                String?
  barrioId           Int?     @map("barrio_id")
  inmueble_id         Int      @unique @map("inmueble_id")
  ubicacion_maestra_id Int?    @map("ubicacion_maestra_id")

  inmueble          Inmueble           @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  ubicacion_maestra ubicacion_maestra? @relation(fields: [ubicacion_maestra_id], references: [id])
  barrio             Barrio?            @relation(fields: [barrioId], references: [id], onDelete: SetNull)
  marcadores        MarcadorMapa[]

  @@index([ubicacion_maestra_id])
  @@map("ubicacion_inmueble")
}

model Etiqueta {
  id        Int                @id @default(autoincrement())
  nombre    String             @unique
  inmuebles InmuebleEtiqueta[]

  @@map("etiqueta")
}

model InmuebleEtiqueta {
  inmueble_id Int @map("inmueble_id")
  etiqueta_id Int @map("etiqueta_id")

  inmueble Inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  etiqueta Etiqueta @relation(fields: [etiqueta_id], references: [id], onDelete: Cascade)

  @@id([inmueble_id, etiqueta_id])
  @@map("inmueble_etiqueta")
}

model Amenidad {
  id        Int                @id @default(autoincrement())
  nombre    String             @unique
  inmuebles InmuebleAmenidad[]

  @@map("amenidad")
}

model InmuebleAmenidad {
  inmueble_id Int @map("inmueble_id")
  amenidad_id Int @map("amenidad_id")

  inmueble Inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  amenidad Amenidad @relation(fields: [amenidad_id], references: [id], onDelete: Cascade)

  @@id([inmueble_id, amenidad_id])
  @@map("inmueble_amenidad")
}

// ─────────────────────────────────────────────
// PUBLICACIONES Y MULTIMEDIA
// ─────────────────────────────────────────────

model Publicacion {
  id                Int               @id @default(autoincrement())
  titulo            String
  descripcion       String?
  estado            EstadoPublicacion  @default(ACTIVA)
  fecha_publicacion DateTime          @default(now()) @map("fecha_publicacion")
  usuario_id        Int               @map("usuario_id")
  inmueble_id       Int               @map("inmueble_id")

  usuario    Usuario                @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  inmueble   Inmueble               @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  multimedia Multimedia[]
  parametros PublicacionParametro[]

  @@index([usuario_id])
  @@index([inmueble_id])
  @@index([estado])
  @@map("publicacion")
}

model ParametroPersonalizado {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(255)
  descripcion String?
  creado_en   DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)

  publicacion_parametro PublicacionParametro[]

  @@map("parametros_personalizados")
}

model PublicacionParametro {
  id             Int      @id @default(autoincrement())
  publicacion_id Int      @map("publicacion_id")
  parametro_id   Int      @map("parametro_id")
  valor          String?
  creado_en      DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)

  publicacion Publicacion            @relation(fields: [publicacion_id], references: [id], onDelete: Cascade)
  parametro   ParametroPersonalizado @relation(fields: [parametro_id], references: [id], onDelete: Cascade)

  @@unique([publicacion_id, parametro_id], map: "uq_publicacion_parametro")
  @@index([publicacion_id], map: "idx_publicacion_parametro_publicacion")
  @@index([parametro_id],   map: "idx_publicacion_parametro_parametro")
  @@map("publicacion_parametro")
}

model Multimedia {
  id             Int            @id @default(autoincrement())
  url            String
  tipo           TipoMultimedia
  peso_mb        Decimal?       @db.Decimal(8, 2) @map("peso_mb")
  publicacion_id Int            @map("publicacion_id")

  publicacion Publicacion @relation(fields: [publicacion_id], references: [id], onDelete: Cascade)

  @@index([publicacion_id])
  @@map("multimedia")
}

// ─────────────────────────────────────────────
// MAPA
// ─────────────────────────────────────────────

model MarcadorMapa {
  id          Int          @id @default(autoincrement())
  tipo        TipoMarcador
  es_visible  Boolean      @default(true) @map("es_visible")
  nivel_z     Int?         @map("nivel_z")
  inmueble_id Int          @map("inmueble_id")
  ubicacion_id Int         @map("ubicacion_id")

  inmueble      Inmueble          @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  ubicacion     UbicacionInmueble @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade)
  grupos        DetalleGrupo[]
  interacciones InteraccionMapa[]

  @@index([inmueble_id])
  @@index([ubicacion_id])
  @@map("marcador_mapa")
}

model GrupoMarcadores {
  id                 Int      @id @default(autoincrement())
  latitud_centro     Decimal  @db.Decimal(10, 7) @map("latitud_centro")
  longitud_centro    Decimal  @db.Decimal(10, 7) @map("longitud_centro")
  cantidad_inmuebles Int      @map("cantidad_inmuebles")
  nivel_color        String?  @map("nivel_color")
  nivel_zoom         Int      @map("nivel_zoom")
  radio_km           Decimal? @db.Decimal(10, 2) @map("radio_km")
  actualizado_en     DateTime @updatedAt @map("actualizado_en")

  marcadores DetalleGrupo[]

  @@map("grupo_marcadores")
}

model DetalleGrupo {
  grupo_id    Int @map("grupo_id")
  marcador_id Int @map("marcador_id")

  grupo    GrupoMarcadores @relation(fields: [grupo_id], references: [id], onDelete: Cascade)
  marcador MarcadorMapa    @relation(fields: [marcador_id], references: [id], onDelete: Cascade)

  @@id([grupo_id, marcador_id])
  @@map("detalle_grupo")
}

model SesionMapa {
  id               Int      @id @default(autoincrement())
  token            String   @unique @db.VarChar(512)
  nivel_zoom       Int      @map("nivel_zoom")
  iniciado_en      DateTime @default(now()) @map("iniciado_en")
  ultima_actividad DateTime @updatedAt      @map("ultima_actividad")

  limite_norte    Decimal? @db.Decimal(10, 7) @map("limite_norte")
  limite_sur      Decimal? @db.Decimal(10, 7) @map("limite_sur")
  limite_este     Decimal? @db.Decimal(10, 7) @map("limite_este")
  limite_oeste    Decimal? @db.Decimal(10, 7) @map("limite_oeste")
  latitud_centro  Decimal? @db.Decimal(10, 7) @map("latitud_centro")
  longitud_centro Decimal? @db.Decimal(10, 7) @map("longitud_centro")

  interacciones InteraccionMapa[]

  @@map("sesion_mapa")
}

model InteraccionMapa {
  id               Int             @id @default(autoincrement())
  tipo             TipoInteraccion
  ocurrio_en       DateTime        @default(now()) @map("ocurrio_en")
  sesion_id        Int             @map("sesion_id")
  marcador_id      Int             @map("marcador_id")
  latitud_momento  Decimal?        @db.Decimal(10, 7) @map("latitud_momento")
  longitud_momento Decimal?        @db.Decimal(10, 7) @map("longitud_momento")
  zoom_momento     Int?            @map("zoom_momento")

  sesion   SesionMapa   @relation(fields: [sesion_id], references: [id], onDelete: Cascade)
  marcador MarcadorMapa @relation(fields: [marcador_id], references: [id], onDelete: Cascade)

  @@index([sesion_id])
  @@index([marcador_id])
  @@map("interaccion_mapa")
}

// ─────────────────────────────────────────────
// PAGOS Y SUSCRIPCIONES
// ─────────────────────────────────────────────

model plan_suscripcion {
  id                      Int      @id @default(autoincrement())
  nombre_plan             String?  @db.VarChar(50)
  descripcion_plan        String?
  precio_plan             Decimal? @db.Decimal(10, 2)
  duracion_plan_dias      Int?
  nro_publicaciones_plan  Int?
  imagen_gr_url           String?  @db.VarChar(255)

  bitacora_pagos        bitacora_pagos[]
  suscripciones_activas suscripciones_activas[]
  transacciones         transacciones[]

  @@map("plan_suscripcion")
}

model transacciones {
  id                      Int      @id @default(autoincrement())
  usuario_id              Int      @map("usuario_id")
  suscripcion_id          Int      @map("suscripcion_id")
  subtotal                Decimal  @db.Decimal(10, 2)
  iva_porcentaje          Decimal  @db.Decimal(5, 2)
  iva_monto               Decimal  @db.Decimal(10, 2)
  total                   Decimal  @db.Decimal(10, 2)
  metodo_pago             String   @default("QR_BANCARIO") @map("metodo_pago") @db.VarChar(30)
  fecha_intento           DateTime @default(now()) @map("fecha_intento")       @db.Timestamptz(6)
  fecha_completado        DateTime? @map("fecha_completado")                   @db.Timestamptz(6)
  estado                  String   @default("PENDIENTE") @map("estado")        @db.VarChar(20)
  verificacion_requerida  Boolean  @default(true) @map("verificacion_requerida")
  tiempo_activacion       DateTime? @map("tiempo_activacion")                  @db.Timestamptz(6)

  usuario               Usuario               @relation(fields: [usuario_id], references: [id])
  plan_suscripcion      plan_suscripcion      @relation(fields: [suscripcion_id], references: [id])
  bitacora_pagos        bitacora_pagos[]
  suscripciones_activas suscripciones_activas[]
  verificacion_pago     verificacion_pago[]

  @@index([estado],      map: "idx_transacciones_estado")
  @@index([usuario_id],  map: "idx_transacciones_usuario_id")
  @@map("transacciones")
}

model suscripciones_activas {
  id              Int      @id @default(autoincrement())
  usuario_id      Int      @map("usuario_id")
  suscripcion_id  Int      @map("suscripcion_id")
  transaccion_id  Int      @map("transaccion_id")
  fecha_inicio    DateTime @map("fecha_inicio") @db.Timestamptz(6)
  fecha_fin       DateTime @map("fecha_fin")    @db.Timestamptz(6)
  estado          String   @default("INACTIVA") @map("estado") @db.VarChar(20)

  usuario          Usuario          @relation(fields: [usuario_id], references: [id])
  plan_suscripcion plan_suscripcion @relation(fields: [suscripcion_id], references: [id])
  transacciones    transacciones    @relation(fields: [transaccion_id], references: [id])

  @@index([usuario_id])
  @@index([estado])
  @@map("suscripciones_activas")
}

model bitacora_pagos {
  id              Int      @id @default(autoincrement())
  usuario_id      Int      @map("usuario_id")
  suscripcion_id  Int?     @map("suscripcion_id")
  transaccion_id  Int?     @map("transaccion_id")
  evento          String   @db.VarChar(100)
  mensaje         String?
  fecha_evento    DateTime @default(now()) @map("fecha_evento") @db.Timestamptz(6)

  usuario          Usuario           @relation(fields: [usuario_id], references: [id])
  plan_suscripcion plan_suscripcion? @relation(fields: [suscripcion_id], references: [id])
  transacciones    transacciones?    @relation(fields: [transaccion_id], references: [id])

  @@index([fecha_evento],    map: "idx_bitacora_fecha_evento")
  @@index([transaccion_id],  map: "idx_bitacora_transaccion_id")
  @@index([usuario_id])
  @@map("bitacora_pagos")
}

model verificacion_pago {
  id                     Int      @id @default(autoincrement())
  transaccion_id         Int      @map("transaccion_id")
  admin_id               Int      @map("admin_id")
  fecha_verificacion     DateTime @default(now()) @map("fecha_verificacion") @db.Timestamptz(6)
  resultado_verificacion String   @default("VERIFICADO") @map("resultado_verificacion") @db.VarChar(20)

  usuario       Usuario       @relation(fields: [admin_id], references: [id])
  transacciones transacciones @relation(fields: [transaccion_id], references: [id])

  @@index([transaccion_id])
  @@index([admin_id])
  @@map("verificacion_pago")
}

// ─────────────────────────────────────────────
// ACTIVIDAD DE USUARIOS
// ─────────────────────────────────────────────

model propiedad_vista {
  id          Int      @id @default(autoincrement())
  usuario_id  Int      @map("usuario_id")
  inmueble_id Int      @map("inmueble_id")
  vista_en    DateTime @default(now()) @map("vista_en")
  veces_visto Int      @default(1)    @map("veces_visto")

  inmueble Inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, inmueble_id])
  @@index([usuario_id, vista_en])
  @@map("propiedad_vista")
}

model favorito {
  id          Int      @id @default(autoincrement())
  usuario_id  Int      @map("usuario_id")
  inmueble_id Int      @map("inmueble_id")
  agregado_en DateTime @default(now()) @map("agregado_en")

  inmueble Inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)
  usuario  Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, inmueble_id])
  @@index([usuario_id])
  @@map("favorito")
}

model historial_busqueda {
  id         Int      @id @default(autoincrement())
  usuario_id Int      @map("usuario_id")
  termino    String
  creado_en  DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id, creado_en])
  @@map("historial_busqueda")
}

model comparacion {
  id         Int      @id @default(autoincrement())
  nombre     String?  @db.VarChar(100)
  creado_en  DateTime @default(now()) @map("creado_en")
  usuario_id Int      @map("usuario_id")

  usuario  Usuario               @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  detalles detalle_comparacion[]

  @@index([usuario_id])
  @@map("comparacion")
}

model detalle_comparacion {
  id             Int @id @default(autoincrement())
  comparacion_id Int @map("comparacion_id")
  inmueble_id    Int @map("inmueble_id")
  orden          Int @default(0)

  comparacion comparacion @relation(fields: [comparacion_id], references: [id], onDelete: Cascade)
  inmueble    Inmueble    @relation(fields: [inmueble_id], references: [id], onDelete: Cascade)

  @@unique([comparacion_id, inmueble_id])
  @@index([inmueble_id])
  @@map("detalle_comparacion")
}

// ─────────────────────────────────────────────
// UBICACIONES Y ZONAS
// ─────────────────────────────────────────────

model ubicacion_maestra {
  id           Int     @id @default(autoincrement())
  departamento String
  provincia    String?
  municipio    String?
  nombre       String
  latitud      Decimal @db.Decimal(10, 7)
  longitud     Decimal @db.Decimal(10, 7)
  popularidad  Int     @default(0)

  ubicacion_inmueble UbicacionInmueble[]

  @@index([nombre])
  @@map("ubicacion_maestra")
}

model zona_predefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creado_en   DateTime @default(now()) @map("creado_en")

  @@map("zona_predefinida")
}

model zona_usuario {
  id             Int      @id @default(autoincrement())
  nombre         String   @db.VarChar(100)
  descripcion    String?
  geometria      Json
  area           Decimal? @db.Decimal(12, 4)
  creado_en      DateTime @default(now()) @map("creado_en")
  actualizado_en DateTime @updatedAt      @map("actualizado_en")
  usuario_id     Int      @map("usuario_id")

  usuario Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@map("zona_usuario")
}

model Departamento {
  id         Int         @id @default(autoincrement())
  nombre     String      @unique 
  provincias Provincia[]
  @@map("departamento")
}

model Provincia {
  id             Int          @id @default(autoincrement())
  nombre         String       
  departamentoId Int          @map("departamento_id")
  departamento   Departamento @relation(fields: [departamentoId], references: [id], onDelete: Cascade)
  municipios     Municipio[]
  @@unique([nombre, departamentoId])
  @@map("provincia")
}

model Municipio {
  id          Int         @id @default(autoincrement())
  nombre      String      
  provinciaId Int         @map("provincia_id")
  provincia   Provincia   @relation(fields: [provinciaId], references: [id], onDelete: Cascade)
  zonas       Zona[]
  @@unique([nombre, provinciaId])
  @@map("municipio")
}

model Zona {
  id          Int        @id @default(autoincrement())
  nombre      String     
  municipioId Int        @map("municipio_id")
  municipio   Municipio  @relation(fields: [municipioId], references: [id], onDelete: Cascade)
  barrios     Barrio[]
  @@unique([nombre, municipioId])
  @@map("zona_geografica")
}

model Barrio {
  id          Int    @id @default(autoincrement())
  nombre      String 
  zonaId      Int    @map("zona_id")
  zona        Zona   @relation(fields: [zonaId], references: [id], onDelete: Cascade)
  
  // Conexión a la propiedad
  ubicaciones UbicacionInmueble[] 
  @@unique([nombre, zonaId])
  @@map("barrio")
}

// ─────────────────────────────────────────────
// CIUDADES Y BANNERS
// ─────────────────────────────────────────────

model ciudad {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  slug        String   @unique
  descripcion String?
  popularidad Int      @default(0)

  imagenes ciudad_imagen[]

  @@map("ciudad")
}

model ciudad_imagen {
  id         Int    @id @default(autoincrement())
  ciudad_id  Int    @map("ciudad_id")
  url        String
  orden      Int    @default(0)

  ciudad ciudad @relation(fields: [ciudad_id], references: [id], onDelete: Cascade)

  @@index([ciudad_id])
  @@map("ciudad_imagen")
}

model BannerHome {
  id             Int      @id @default(autoincrement())
  url_imagen     String   @map("url_imagen")
  orden          Int
  activo         Boolean  @default(true)
  fecha_creacion DateTime @default(now()) @map("fecha_creacion")
  titulo         String?
  subtitulo      String?

  @@map("banner_home")
}

// ─────────────────────────────────────────────
// ANALÍTICA
// ─────────────────────────────────────────────

model Visitor {
  id           Int      @id @default(autoincrement())
  ip           String
  meta_data    Json?    @map("meta_data")
  fecha_visita DateTime @default(now()) @map("fecha_visita")
  usuario_id   Int?     @map("usuario_id")

  usuario Usuario? @relation(fields: [usuario_id], references: [id])

  @@index([usuario_id])
  @@map("visitor")
}

// ─────────────────────────────────────────────
// SPATIAL (solo referencia, no modificar)
// ─────────────────────────────────────────────

model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)

  @@map("spatial_ref_sys")
}

