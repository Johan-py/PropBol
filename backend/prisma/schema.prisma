generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

model autenticacion_social {
  id              Int       @id @default(autoincrement())
  usuarioId       Int
  proveedor       String    @db.VarChar(30)
  correoProveedor String?   @db.VarChar(100)
  idExterno       String    @db.VarChar(150)
  vinculadoEn     DateTime? @default(now()) @db.Timestamp(6)
  activo          Boolean?  @default(true)
  usuario         usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([proveedor, idExterno], map: "autenticacion_social_proveedor_idexterno_key")
  @@unique([usuarioId, proveedor], map: "autenticacion_social_usuario_proveedor_key")
}

model banner_home {
  id            Int      @id @default(autoincrement())
  urlImagen     String
  orden         Int
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())
  titulo        String?
  subtitulo     String?
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onUpdate: NoAction)
  usuario          usuario?          @relation(fields: [id_usuario], references: [id], onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha_evento")
  @@index([id_transaccion], map: "idx_bitacora_transaccion_id")
}

model cambio_email {
  id           Int       @id @default(autoincrement())
  emailNuevo   String
  token        String    @unique
  expiraEn     DateTime
  creadoEn     DateTime  @default(now())
  completadoEn DateTime?
  usuarioId    Int
  usuario      usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model codigo_2fa {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  codigoHash String    @db.VarChar(255)
  creadoEn   DateTime? @default(now()) @db.Timestamp(6)
  expiraEn   DateTime  @db.Timestamp(6)
  usadoEn    DateTime? @db.Timestamp(6)
  intentos   Int?      @default(0)
  activo     Boolean?  @default(true)
  usuario    usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "codigo_2fa_usuario_fecha_idx")
}

model comparacion {
  id                  Int                   @id @default(autoincrement())
  nombre              String?               @db.VarChar(100)
  creadoEn            DateTime              @default(now())
  usuarioId           Int
  usuario             usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  detalle_comparacion detalle_comparacion[]
}

model cupon {
  id              Int             @id @default(autoincrement())
  codigo          String          @unique @db.VarChar(50)
  descripcion     String?
  tipo_descuento  String          @default("PORCENTAJE") @db.VarChar(10)
  valor_descuento Decimal         @db.Decimal(10, 2)
  max_usos        Int             @default(1)
  usos_actuales   Int             @default(0)
  fecha_inicio    DateTime        @default(now()) @db.Timestamptz(6)
  fecha_fin       DateTime        @db.Timestamptz(6)
  activo          Boolean?        @default(true)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  transacciones   transacciones[]
}

model detalle_comparacion {
  id            Int         @id @default(autoincrement())
  comparacionId Int
  inmuebleId    Int
  orden         Int         @default(0)
  comparacion   comparacion @relation(fields: [comparacionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inmueble      inmueble    @relation(fields: [inmuebleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([comparacionId, inmuebleId])
}

model detalle_grupo {
  grupoId          Int
  marcadorId       Int
  grupo_marcadores grupo_marcadores @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  marcador_mapa    marcador_mapa    @relation(fields: [marcadorId], references: [id], onDelete: Cascade)

  @@id([grupoId, marcadorId])
}

model etiqueta {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique
  inmueble_etiqueta inmueble_etiqueta[]
}

model favorito {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  agregadoEn DateTime? @default(now()) @db.Timestamp(6)
  inmueble   inmueble  @relation(fields: [inmuebleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario    usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuarioId, inmuebleId], map: "favorito_unique")
  @@unique([usuarioId, inmuebleId])
}

model grupo_marcadores {
  id                Int             @id @default(autoincrement())
  latitudCentro     Decimal         @db.Decimal(10, 7)
  longitudCentro    Decimal         @db.Decimal(10, 7)
  cantidadInmuebles Int
  nivelColor        String?
  nivelZoom         Int
  radioKm           Decimal?        @db.Decimal(10, 2)
  actualizadoEn     DateTime
  detalle_grupo     detalle_grupo[]
}

model historial_password {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  passwordHash String    @db.VarChar(255)
  creadoEn     DateTime? @default(now()) @db.Timestamp(6)
  usuario      usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "historial_password_usuario_fecha_idx")
}

model inmueble {
  id                  Int                   @id @default(autoincrement())
  titulo              String
  tipoAccion          TipoAccion
  categoria           Categoria?
  precio              Decimal               @db.Decimal(12, 2)
  superficieM2        Decimal?              @db.Decimal(10, 2)
  nroCuartos          Int?
  nroBanos            Int?
  descripcion         String?
  estado              EstadoInmueble        @default(ACTIVO)
  fechaPublicacion    DateTime              @default(now())
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  propietarioId       Int
  detalle_comparacion detalle_comparacion[]
  favorito            favorito[]
  usuario             usuario               @relation(fields: [propietarioId], references: [id], onDelete: Cascade)
  inmueble_etiqueta   inmueble_etiqueta[]
  marcador_mapa       marcador_mapa[]
  propiedad_vista     propiedad_vista[]
  publicacion         publicacion[]
  ubicacion_inmueble  ubicacion_inmueble?

  @@index([propietarioId])
}

model inmueble_etiqueta {
  inmuebleId Int
  etiquetaId Int
  etiqueta   etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  inmueble   inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@id([inmuebleId, etiquetaId])
}

model interaccion_mapa {
  id              Int             @id @default(autoincrement())
  tipo            TipoInteraccion
  latitudMomento  Decimal?        @db.Decimal(10, 7)
  longitudMomento Decimal?        @db.Decimal(10, 7)
  zoomMomento     Int?
  ocurrioEn       DateTime        @default(now())
  sesionId        Int
  marcadorId      Int
  marcador_mapa   marcador_mapa   @relation(fields: [marcadorId], references: [id], onDelete: Cascade)
  sesion_mapa     sesion_mapa     @relation(fields: [sesionId], references: [id], onDelete: Cascade)
}

model marcador_mapa {
  id                 Int                @id @default(autoincrement())
  tipo               TipoMarcador
  esVisible          Boolean            @default(true)
  nivelZ             Int?
  inmuebleId         Int
  ubicacionId        Int
  detalle_grupo      detalle_grupo[]
  interaccion_mapa   interaccion_mapa[]
  inmueble           inmueble           @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion_inmueble ubicacion_inmueble @relation(fields: [ubicacionId], references: [id], onDelete: Cascade)
}

model multimedia {
  id            Int            @id @default(autoincrement())
  url           String
  tipo          TipoMultimedia
  pesoMb        Decimal?       @db.Decimal(8, 2)
  publicacionId Int
  publicacion   publicacion    @relation(fields: [publicacionId], references: [id], onDelete: Cascade)
}

model notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean   @default(false)
  fechaCreacion DateTime  @default(now())
  fechaLectura  DateTime?
  eliminada     Boolean   @default(false)
  usuarioId     Int
  archivada     Boolean?  @default(false)
  usuario       usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model perfil {
  id             Int     @id @default(autoincrement())
  nombreCompleto String
  datos          Json?
  usuarioId      Int     @unique
  usuario        usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String                  @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal                 @db.Decimal(10, 2)
  duracion_plan_dias     Int
  nro_publicaciones_plan Int
  imagen_gr_url          String?                 @db.VarChar(255)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model propiedad_vista {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  vistaEn    DateTime? @default(now()) @db.Timestamp(6)
  inmueble   inmueble  @relation(fields: [inmuebleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario    usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuarioId, inmuebleId], map: "propiedad_vista_unique")
  @@unique([usuarioId, inmuebleId])
  @@index([usuarioId, vistaEn])
  @@index([usuarioId, vistaEn], map: "propiedad_vista_usuario_fecha")
}

model publicacion {
  id               Int               @id @default(autoincrement())
  titulo           String
  descripcion      String?
  estado           EstadoPublicacion @default(ACTIVA)
  fechaPublicacion DateTime          @default(now())
  usuarioId        Int
  inmuebleId       Int
  multimedia       multimedia[]
  inmueble         inmueble          @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario          usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model recuperacion_password {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  token     String    @unique @db.VarChar(255)
  expiraEn  DateTime  @db.Timestamp(6)
  creadoEn  DateTime? @default(now()) @db.Timestamp(6)
  usadoEn   DateTime? @db.Timestamp(6)
  intentos  Int?      @default(0)
  activo    Boolean?  @default(true)
  usuario   usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "recuperacion_password_usuario_fecha_idx")
}

model rol {
  id      Int       @id @default(autoincrement())
  nombre  RolNombre @unique
  usuario usuario[]
}

model sesion {
  id              Int      @id @default(autoincrement())
  token           String   @unique
  fechaInicio     DateTime @default(now())
  fechaExpiracion DateTime
  estado          Boolean  @default(true)
  usuarioId       Int
  usuario         usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model sesion_mapa {
  id               Int                @id @default(autoincrement())
  token            String             @unique
  limiteNorte      Decimal?           @db.Decimal(10, 7)
  limiteSur        Decimal?           @db.Decimal(10, 7)
  limiteEste       Decimal?           @db.Decimal(10, 7)
  limiteOeste      Decimal?           @db.Decimal(10, 7)
  nivelZoom        Int
  latitudCentro    Decimal?           @db.Decimal(10, 7)
  longitudCentro   Decimal?           @db.Decimal(10, 7)
  iniciadoEn       DateTime           @default(now())
  ultimaActividad  DateTime
  interaccion_mapa interaccion_mapa[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model telefono {
  id         Int     @id @default(autoincrement())
  codigoPais String
  numero     String
  principal  Boolean @default(false)
  usuarioId  Int
  usuario    usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  cupon_id               Int?
  monto_descuento        Decimal?                @default(0) @db.Decimal(10, 2)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  cupon                  cupon?                  @relation(fields: [cupon_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario_id")
}

model ubicacion_inmueble {
  id                 Int                @id @default(autoincrement())
  latitud            Decimal            @db.Decimal(10, 7)
  longitud           Decimal            @db.Decimal(10, 7)
  direccion          String?
  zona               String?
  ciudad             String
  inmuebleId         Int                @unique
  ubicacionMaestraId Int?
  marcador_mapa      marcador_mapa[]
  inmueble           inmueble           @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion_maestra  ubicacion_maestra? @relation(fields: [ubicacionMaestraId], references: [id])
}

model ubicacion_maestra {
  id                 Int                  @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal              @db.Decimal(10, 7)
  longitud           Decimal              @db.Decimal(10, 7)
  popularidad        Int                  @default(0)
  ubicacion_inmueble ubicacion_inmueble[]

  @@index([nombre])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model usuario {
  id                             Int                     @id @default(autoincrement())
  nombre                         String
  apellido                       String
  correo                         String                  @unique
  password                       String
  pais                           String?
  avatar                         String?
  genero                         Genero?
  direccion                      String?
  activo                         Boolean                 @default(true)
  fechaRegistro                  DateTime                @default(now())
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime
  rolId                          Int
  fechaNacimiento                DateTime?               @db.Timestamp(6)
  zonaConexion                   String?                 @default("") @db.VarChar
  telemetriaCompartida           Boolean?                @default(false)
  intentosFallidosCambioPassword Int?                    @default(0)
  bloqueoCambioPasswordHasta     DateTime?
  passwordActualizadoEn          DateTime?
  twoFactorActivo                Boolean?                @default(false)
  twoFactorMetodo                String?                 @default("EMAIL") @db.VarChar(20)
  twoFactorActivadoEn            DateTime?
  desactivadoEn                  DateTime?
  notificacionEmail              Boolean?                @default(true)
  notificacionWhatsapp           Boolean?                @default(false)
  autenticacion_social           autenticacion_social[]
  bitacora_pagos                 bitacora_pagos[]
  cambio_email                   cambio_email[]
  codigo_2fa                     codigo_2fa[]
  comparacion                    comparacion[]
  favorito                       favorito[]
  historial_password             historial_password[]
  inmueble                       inmueble[]
  notificacion                   notificacion[]
  perfil                         perfil?
  propiedad_vista                propiedad_vista[]
  publicacion                    publicacion[]
  recuperacion_password          recuperacion_password[]
  sesion                         sesion[]
  suscripciones_activas          suscripciones_activas[]
  telefono                       telefono[]
  transacciones                  transacciones[]
  rol                            rol                     @relation(fields: [rolId], references: [id])
  verificacion_pago              verificacion_pago[]
  visitor                        visitor[]
  zona_usuario                   zona_usuario[]

  @@index([correo])
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model visitor {
  id          Int      @id @default(autoincrement())
  ip          String
  metaData    Json?
  fechaVisita DateTime @default(now())
  usuarioId   Int?
  usuario     usuario? @relation(fields: [usuarioId], references: [id])
}

model zona_usuario {
  id            Int       @id @default(autoincrement())
  nombre        String    @db.VarChar(100)
  descripcion   String?
  geometria     Json
  area          Decimal?  @db.Decimal(12, 4)
  creadoEn      DateTime? @default(now()) @db.Timestamp(6)
  actualizadoEn DateTime  @db.Timestamp(6)
  usuarioId     Int
  usuario       usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
}

enum EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO
}

enum EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO
}

enum TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG
}

enum TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER
}

enum TipoMultimedia {
  IMAGEN
  VIDEO
}
