  desactivado_en                        DateTime?               @db.Timestamp(6)
  fecha_nacimiento                      DateTime?               @db.Timestamp(6)
  telemetria_compartida                 Boolean?                @default(false)
  zona_conexion                         String?                 @db.VarChar(100)
  autenticacion_social                  autenticacion_social[]
  bitacora_pagos                        bitacora_pagos[]
  blog                                  blog[]
  cambio_email                          cambio_email[]
  codigo_2fa                            codigo_2fa[]
  comentario                            comentario[]
  comentario_like                       comentario_like[]
  comparacion                           comparacion[]
  favorito                              favorito[]
  historial_busqueda                    historial_busqueda[]
  historial_password                    historial_password[]
  inmueble                              inmueble[]
  notificacion                          notificacion[]
  perfil                                perfil?
  propiedad_vista                       propiedad_vista[]
  publicacion                           publicacion[]
  recuperacion_password                 recuperacion_password[]
  sesion                                sesion[]
  suscripciones_activas                 suscripciones_activas[]
  telefono_telefono_usuarioIdTousuario  telefono[]              @relation("telefono_usuarioIdTousuario")
  telefono_telefono_usuario_idTousuario telefono[]              @relation("telefono_usuario_idTousuario")
  transacciones                         transacciones[]
  rol                                   rol?                    @relation(fields: [rolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago                     verificacion_pago[]
  visitor                               visitor[]
  zona_usuario                          zona_usuario[]

  @@index([correo], map: "idx_usuario_correo")
  @@index([rolId], map: "idx_usuario_rol")
  @@index([rolId], map: "idx_usuario_rol_id")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model visitor {
  id           Int       @id @default(autoincrement())
  ip           String
  meta_data    Json?
  fecha_visita DateTime? @default(now()) @db.Timestamp(6)
  usuario_id   Int?
  usuario      usuario?  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model zona_predefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())
}

model zona_usuario {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  descripcion   String?
  geometria     Json
  area          Decimal? @db.Decimal(12, 4)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime
  usuarioId     Int
  usuario       usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model blog {
  id                Int            @id @default(autoincrement())
  titulo            String
  contenido         String
  imagen            String?
  estado            estado_blog
  eliminado         Boolean?       @default(false)
  fecha_creacion    DateTime?      @default(now()) @db.Timestamp(6)
  fecha_publicacion DateTime?      @db.Timestamp(6)
  usuario_id        Int
  categoria_id      Int
  categoria_blog    categoria_blog @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_categoria_fk")
  usuario           usuario        @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_usuario_fk")
  blog_rechazo      blog_rechazo[]
  comentario        comentario[]

  @@index([estado])
  @@index([usuario_id], map: "blog_usuario_idx")
}

model blog_rechazo {
  id         Int       @id @default(autoincrement())
  comentario String
  fecha      DateTime? @default(now()) @db.Timestamp(6)
  blog_id    Int
  blog       blog      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_rechazo_blog_fk")
}

model categoria_blog {
  id     Int    @id @default(autoincrement())
  nombre String @unique @db.VarChar(100)
  blog   blog[]
}

model comentario {
  id                  Int               @id @default(autoincrement())
  contenido           String
  fecha_creacion      DateTime?         @default(now()) @db.Timestamp(6)
  usuario_id          Int
  blog_id             Int
  comentario_padre_id Int?
  blog                blog              @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_blog_fk")
  comentario          comentario?       @relation("comentarioTocomentario", fields: [comentario_padre_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_padre_fk")
  other_comentario    comentario[]      @relation("comentarioTocomentario")
  usuario             usuario           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_usuario_fk")
  comentario_like     comentario_like[]

  @@index([blog_id], map: "comentario_blog_idx")
}

model comentario_like {
  id            Int        @id @default(autoincrement())
  usuario_id    Int
  comentario_id Int
  comentario    comentario @relation(fields: [comentario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_comentario_fk")
  usuario       usuario    @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_usuario_fk")

  @@unique([usuario_id, comentario_id], map: "comentario_like_unique")
}

model amenidad {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique @db.VarChar(255)
  inmueble_amenidad inmueble_amenidad[]
}

model barrio {
  id                                                      Int                  @id @default(autoincrement())
  nombre                                                  String               @db.VarChar(255)
  zona_id                                                 Int
  zona_geografica                                         Int?
  zona_geografica_barrio_zona_idTozona_geografica         zona_geografica      @relation("barrio_zona_idTozona_geografica", fields: [zona_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "barrio_zona_fk")
  zona_geografica_barrio_zona_geograficaTozona_geografica zona_geografica?     @relation("barrio_zona_geograficaTozona_geografica", fields: [zona_geografica], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ubicacion_inmueble                                      ubicacion_inmueble[]

  @@unique([nombre, zona_id], map: "barrio_nombre_zona_unique")
}

model departamento {
  id                                             Int         @id @default(autoincrement())
  nombre                                         String      @unique @db.VarChar(255)
  provincia_provincia_departamentoTodepartamento provincia[] @relation("provincia_departamentoTodepartamento")
}

model inmueble_amenidad {
  inmueble_id Int
  amenidad_id Int
  amenidad    amenidad @relation(fields: [amenidad_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_amenidad_fk")
  inmueble    inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_inmueble_fk")

  @@id([inmueble_id, amenidad_id])
}

model municipio {
  id                                                   Int               @id @default(autoincrement())
  nombre                                               String            @db.VarChar(255)
  provincia                                            Int
  provincia_id                                         Int?
  provincia_municipio_provinciaToprovincia             provincia         @relation("municipio_provinciaToprovincia", fields: [provincia], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zona_geografica_zona_geografica_municipioTomunicipio zona_geografica[] @relation("zona_geografica_municipioTomunicipio")

  @@unique([nombre, provincia], map: "municipio_nombre_provincia_unique")
}

model provincia {
  id                                                Int          @id @default(autoincrement())
  nombre                                            String       @db.VarChar(255)
  departamento                                      Int
  departamento_id                                   Int?
  municipio_municipio_provinciaToprovincia          municipio[]  @relation("municipio_provinciaToprovincia")
  departamento_provincia_departamentoTodepartamento departamento @relation("provincia_departamentoTodepartamento", fields: [departamento], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nombre, departamento], map: "provincia_nombre_departamento_unique")
}

model zona_geografica {
  id                                             Int       @id @default(autoincrement())
  nombre                                         String    @db.VarChar(255)
  municipio                                      Int
  municipio_id                                   Int?
  barrio_barrio_zona_idTozona_geografica         barrio[]  @relation("barrio_zona_idTozona_geografica")
  barrio_barrio_zona_geograficaTozona_geografica barrio[]  @relation("barrio_zona_geograficaTozona_geografica")
  municipio_zona_geografica_municipioTomunicipio municipio @relation("zona_geografica_municipioTomunicipio", fields: [municipio], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nombre, municipio], map: "zona_geografica_nombre_municipio_unique")
}

