generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model audit_log {
  id          Int       @default(autoincrement())
  query       String?
  executed_at DateTime? @default(now()) @db.Timestamp(6)

  @@ignore
}

model autenticacion_social {
  id              Int       @id @default(autoincrement())
  usuarioId       Int
  proveedor       String    @db.VarChar(30)
  correoProveedor String?   @db.VarChar(100)
  idExterno       String    @db.VarChar(150)
  vinculadoEn     DateTime? @default(now()) @db.Timestamp(6)
  activo          Boolean?  @default(true)
  usuario         usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([proveedor, idExterno], map: "autenticacion_social_proveedor_idexterno_key")
  @@unique([usuarioId, proveedor], map: "autenticacion_social_usuario_proveedor_key")
}

model banner_home {
  id             Int       @id @default(autoincrement())
  url_imagen     String
  orden          Int
  activo         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  titulo         String?
  subtitulo      String?
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha")
}

model cambio_email {
  id            Int       @id @default(autoincrement())
  email_nuevo   String
  token         String    @unique
  expira_en     DateTime  @db.Timestamp(6)
  creado_en     DateTime? @default(now()) @db.Timestamp(6)
  completado_en DateTime? @db.Timestamp(6)
  usuario_id    Int
  usuario       usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model codigo_2fa {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  codigoHash String    @db.VarChar(255)
  creadoEn   DateTime? @default(now()) @db.Timestamp(6)
  expiraEn   DateTime  @db.Timestamp(6)
  usadoEn    DateTime? @db.Timestamp(6)
  intentos   Int?      @default(0)
  activo     Boolean?  @default(true)
  usuario    usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "codigo_2fa_usuario_fecha_idx")
}

model comparacion {
  id        Int      @id @default(autoincrement())
  nombre    String?  @db.VarChar(100)
  creadoEn  DateTime @default(now()) @db.Timestamp(3)
  usuarioId Int

  usuario  usuario                   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  detalles detalle_comparacion[]

  @@map("comparacion")
}

model detalle_comparacion {
  id            Int @id @default(autoincrement())
  comparacionId Int
  inmuebleId    Int
  orden         Int @default(0)

  comparacion comparacion @relation(fields: [comparacionId], references: [id], onDelete: Cascade)
  inmueble    inmueble   @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([comparacionId, inmuebleId])
  @@map("detalle_comparacion")
}

model detalle_grupo {
  grupo_id         Int
  marcador_id      Int
  grupo_marcadores grupo_marcadores @relation(fields: [grupo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  marcador_mapa    marcador_mapa    @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([grupo_id, marcador_id])
}

model etiqueta {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique
  inmueble_etiqueta inmueble_etiqueta[]
}

model favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  agregadoEn DateTime @default(now()) @db.Timestamp(3)

  usuario  usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  inmueble inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
  @@map("favorito")
}

model grupo_marcadores {
  id                 Int             @id @default(autoincrement())
  latitud_centro     Decimal         @db.Decimal(10, 7)
  longitud_centro    Decimal         @db.Decimal(10, 7)
  cantidad_inmuebles Int
  nivel_color        String?
  nivel_zoom         Int
  radio_km           Decimal?        @db.Decimal(10, 2)
  actualizado_en     DateTime?       @default(now()) @db.Timestamp(6)
  detalle_grupo      detalle_grupo[]
}

model historial_password {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  passwordHash String    @db.VarChar(255)
  creadoEn     DateTime? @default(now()) @db.Timestamp(6)
  usuario      usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "historial_password_usuario_fecha_idx")
}

model inmueble {
  id                 Int                 @id @default(autoincrement())
  titulo             String
  tipo_accion        tipo_accion
  categoria          categoria?
  precio             Decimal             @db.Decimal(12, 2)
  superficie_m2      Decimal?            @db.Decimal(10, 2)
  nro_cuartos        Int?
  nro_banos          Int?
  descripcion        String?
  estado             estado_inmueble?    @default(ACTIVO)
  fecha_publicacion  DateTime?           @default(now()) @db.Timestamp(6)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  updated_at         DateTime?           @default(now()) @db.Timestamp(6)
  propietario_id     Int
  usuario            usuario             @relation(fields: [propietario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inmueble_etiqueta  inmueble_etiqueta[]
  marcador_mapa      marcador_mapa[]
  publicacion        publicacion[]
  ubicacion_inmueble ubicacion_inmueble?
  favoritos          favorito[]
  propiedadesVistas  propiedad_vista[]
  detalle_comparacion detalle_comparacion[]

  @@index([propietario_id], map: "idx_inmueble_propietario")
}

model inmueble_etiqueta {
  inmueble_id Int
  etiqueta_id Int
  etiqueta    etiqueta @relation(fields: [etiqueta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inmueble    inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([inmueble_id, etiqueta_id])
}

model interaccion_mapa {
  id               Int              @id @default(autoincrement())
  tipo             tipo_interaccion
  latitud_momento  Decimal?         @db.Decimal(10, 7)
  longitud_momento Decimal?         @db.Decimal(10, 7)
  zoom_momento     Int?
  ocurrio_en       DateTime?        @default(now()) @db.Timestamp(6)
  sesion_id        Int?
  marcador_id      Int?
  marcador_mapa    marcador_mapa?   @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sesion_mapa      sesion_mapa?     @relation(fields: [sesion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model marcador_mapa {
  id                 Int                @id @default(autoincrement())
  tipo               tipo_marcador
  es_visible         Boolean?           @default(true)
  nivel_z            Int?
  inmueble_id        Int
  ubicacion_id       Int
  detalle_grupo      detalle_grupo[]
  interaccion_mapa   interaccion_mapa[]
  inmueble           inmueble           @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ubicacion_inmueble ubicacion_inmueble @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model multimedia {
  id             Int             @id @default(autoincrement())
  url            String
  tipo           tipo_multimedia
  peso_mb        Decimal?        @db.Decimal(8, 2)
  publicacion_id Int
  publicacion    publicacion     @relation(fields: [publicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean?  @default(false)
  fechaCreacion DateTime? @default(now()) @db.Timestamp(6)
  fechaLectura  DateTime? @db.Timestamp(6)
  eliminada     Boolean?  @default(false)
  archivada     Boolean?  @default(false)
  usuarioId     Int
  usuario       usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notificacion_usuario_id_fkey")
}

model perfil {
  id              Int     @id @default(autoincrement())
  nombre_completo String
  datos           Json?
  usuario_id      Int     @unique
  usuario         usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String?                 @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal?                @db.Decimal(10, 2)
  duracion_plan_dias     Int?
  nro_publicaciones_plan Int?
  imagen_gr_url          String?                 @db.VarChar(255)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model propiedad_vista {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  vistaEn    DateTime @default(now()) @db.Timestamp(3)

  usuario  usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  inmueble inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
  @@index([usuarioId, vistaEn])
  @@map("propiedad_vista")
}

model publicacion {
  id                Int                 @id @default(autoincrement())
  titulo            String
  descripcion       String?
  estado            estado_publicacion? @default(ACTIVA)
  fecha_publicacion DateTime?           @default(now()) @db.Timestamp(6)
  usuario_id        Int
  inmueble_id       Int
  multimedia        multimedia[]
  inmueble          inmueble            @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario           usuario             @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model recuperacion_password {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  token     String    @unique @db.VarChar(255)
  expiraEn  DateTime  @db.Timestamp(6)
  creadoEn  DateTime? @default(now()) @db.Timestamp(6)
  usadoEn   DateTime? @db.Timestamp(6)
  intentos  Int?      @default(0)
  activo    Boolean?  @default(true)
  usuario   usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "recuperacion_password_usuario_fecha_idx")
}

model rol {
  id      Int       @id @default(autoincrement())
  nombre  RolNombre @unique
  usuario usuario[]
}

model sesion {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  fechaInicio     DateTime? @default(now()) @db.Timestamp(6)
  fechaExpiracion DateTime  @db.Timestamp(6)
  estado          Boolean?  @default(true)
  usuarioId       Int
  usuario         usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sesion_usuario_id_fkey")
}

model sesion_mapa {
  id               Int                @id @default(autoincrement())
  token            String             @unique
  limite_norte     Decimal?           @db.Decimal(10, 7)
  limite_sur       Decimal?           @db.Decimal(10, 7)
  limite_este      Decimal?           @db.Decimal(10, 7)
  limite_oeste     Decimal?           @db.Decimal(10, 7)
  nivel_zoom       Int
  latitud_centro   Decimal?           @db.Decimal(10, 7)
  longitud_centro  Decimal?           @db.Decimal(10, 7)
  iniciado_en      DateTime?          @default(now()) @db.Timestamp(6)
  ultima_actividad DateTime?          @default(now()) @db.Timestamp(6)
  interaccion_mapa interaccion_mapa[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model telefono {
  id         Int      @id @default(autoincrement())
  codigoPais String
  numero     String
  principal  Boolean? @default(false)
  usuarioId  Int
  usuario    usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario")
}

model ubicacion_inmueble {
  id                   Int                @id @default(autoincrement())
  latitud              Decimal            @db.Decimal(10, 7)
  longitud             Decimal            @db.Decimal(10, 7)
  direccion            String?
  ciudad               String?
  zona                 String?
  inmueble_id          Int                @unique
  ubicacion_maestra_id Int?
  marcador_mapa        marcador_mapa[]
  inmueble             inmueble           @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ubicacion_maestra    ubicacion_maestra? @relation(fields: [ubicacion_maestra_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ubicacion_maestra {
  id                 Int                  @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal              @db.Decimal(10, 7)
  longitud           Decimal              @db.Decimal(10, 7)
  popularidad        Int?                 @default(0)
  ubicacion_inmueble ubicacion_inmueble[]

  @@index([nombre], map: "idx_ubicacion_nombre")
}

model usuario {
  id                                Int                     @id @default(autoincrement())
  nombre                            String
  apellido                          String
  correo                            String                  @unique
  password                          String
  pais                              String?
  avatar                            String?
  genero                            genero?
  direccion                         String?
  activo                            Boolean?                @default(true)
  fechaRegistro                     DateTime?               @default(now()) @db.Timestamp(6)
  createdAt                         DateTime?               @default(now()) @db.Timestamp(6)
  updatedAt                         DateTime?               @default(now()) @db.Timestamp(6)
  rolId                             Int
  intentos_fallidos_cambio_password Int                     @default(0)
  bloqueo_cambio_password_hasta     DateTime?               @db.Timestamptz(6)
  password_actualizado_en           DateTime                @default(now()) @db.Timestamptz(6)
  two_factor_activo                 Boolean                 @default(false)
  two_factor_metodo                 String                  @default("email") @db.VarChar(20)
  two_factor_activado_en            DateTime?               @db.Timestamptz(6)
  intentosFallidosCambioPassword    Int?                    @default(0)
  bloqueoCambioPasswordHasta        DateTime?
  passwordActualizadoEn             DateTime?
  twoFactorActivo                   Boolean?                @default(false)
  twoFactorMetodo                   String?                 @default("EMAIL") @db.VarChar(20)
  twoFactorActivadoEn               DateTime?
  desactivadoEn                     DateTime?
  controlador                       Boolean                 @default(false)
  
  // NUEVOS CAMPOS SPRINT 2
  fechaNacimiento       DateTime?   @db.Timestamp(3)
  zonaConexion          String?     @db.VarChar(100)
  telemetriaCompartida  Boolean?    @default(false)
  
  // RELACIONES EXISTENTES
  autenticacion_social              autenticacion_social[]
  bitacora_pagos                    bitacora_pagos[]
  cambio_email                      cambio_email[]
  codigo_2fa                        codigo_2fa[]
  historial_password                historial_password[]
  inmueble                          inmueble[]
  notificacion                      notificacion[]
  perfil                            perfil?
  publicacion                       publicacion[]
  recuperacion_password             recuperacion_password[]
  sesion                            sesion[]
  suscripciones_activas             suscripciones_activas[]
  telefono                          telefono[]
  transacciones                     transacciones[]
  rol                               rol                     @relation(fields: [rolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago                 verificacion_pago[]
  visitor                           visitor[]
  
  // NUEVAS RELACIONES SPRINT 2
  favoritos             favorito[]
  propiedadesVistas     propiedad_vista[]
  zonasUsuario          zona_usuario[]
  comparaciones         comparacion[]

  @@index([correo], map: "idx_usuario_correo")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model visitor {
  id           Int       @id @default(autoincrement())
  ip           String
  meta_data    Json?
  fecha_visita DateTime? @default(now()) @db.Timestamp(6)
  usuario_id   Int?
  usuario      usuario?  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model zona_predefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())
}

model zona_usuario {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  descripcion   String?
  geometria     Json
  area          Decimal? @db.Decimal(12, 4)
  creadoEn      DateTime @default(now()) @db.Timestamp(3)
  actualizadoEn DateTime @updatedAt @db.Timestamp(3)
  usuarioId     Int

  usuario usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("zona_usuario")
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA
}

enum estado_inmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO
}

enum estado_publicacion {
  ACTIVA
  PAUSADA
  ELIMINADA
}

enum genero {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR
}

enum tipo_accion {
  VENTA
  ALQUILER
  ANTICRETO
}

enum tipo_interaccion {
  CLICK
  HOVER
  ZOOM
  DRAG
}

enum tipo_marcador {
  NORMAL
  DESTACADO
  CLUSTER
}

enum tipo_multimedia {
  IMAGEN
  VIDEO
}