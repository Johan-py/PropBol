generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Rol {
  id       Int       @id @default(autoincrement())
  nombre   RolNombre @unique
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id                                Int                     @id @default(autoincrement())
  nombre                            String
  apellido                          String
  correo                            String                  @unique
  password                          String
  pais                              String?
  avatar                            String?
  genero                            Genero?
  direccion                         String?
  activo                            Boolean?                @default(true)
  fechaRegistro                     DateTime?               @default(now()) @db.Timestamp(6)
  createdAt                         DateTime?               @default(now()) @db.Timestamp(6)
  updatedAt                         DateTime?               @default(now()) @updatedAt @db.Timestamp(6)
  rolId                             Int
  intentos_fallidos_cambio_password Int                     @default(0)
  bloqueo_cambio_password_hasta     DateTime?               @db.Timestamptz(6)
  password_actualizado_en           DateTime                @default(now()) @db.Timestamptz(6)
  two_factor_activo                 Boolean                 @default(false)
  two_factor_metodo                 String                  @default("email") @db.VarChar(20)
  two_factor_activado_en            DateTime?               @db.Timestamptz(6)
  intentosFallidosCambioPassword    Int?                    @default(0)
  bloqueoCambioPasswordHasta        DateTime?
  passwordActualizadoEn             DateTime?
  twoFactorActivo                   Boolean?                @default(false)
  twoFactorMetodo                   String?                 @default("EMAIL") @db.VarChar(20)
  twoFactorActivadoEn               DateTime?
  desactivadoEn                     DateTime?
  controlador                       Boolean                 @default(false)
  fechaNacimiento                   DateTime?
  telemetriaCompartida              Boolean?                @default(false)
  zonaConexion                      String?                 @db.VarChar(100)
  autenticacion_social              autenticacion_social[]
  bitacora_pagos                    bitacora_pagos[]
  cambio_email                      CambioEmail[]
  codigo_2fa                        codigo_2fa[]
  comparacion                       comparacion[]
  favorito                          favorito[]
  historial_password                historial_password[]
  inmuebles                         Inmueble[]
  notificaciones                    Notificacion[]
  perfil                            Perfil?
  propiedad_vista                   propiedad_vista[]
  publicaciones                     Publicacion[]
  recuperacion_password             recuperacion_password[]
  sesiones                          Sesion[]
  suscripciones_activas             suscripciones_activas[]
  telefonos                         Telefono[]
  transacciones                     transacciones[]
  rol                               Rol                     @relation(fields: [rolId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago                 verificacion_pago[]
  visitor                           Visitor[]
  zona_usuario                      zona_usuario[]

  @@index([correo], map: "idx_usuario_correo")
  @@map("usuario")
}

model Telefono {
  id         Int      @id @default(autoincrement())
  codigoPais String
  numero     String
  principal  Boolean? @default(false)
  usuarioId  Int
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("telefono")
}

model Sesion {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  fechaInicio     DateTime? @default(now()) @db.Timestamp(6)
  fechaExpiracion DateTime  @db.Timestamp(6)
  estado          Boolean?  @default(true)
  usuarioId       Int
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sesion_usuario_id_fkey")

  @@map("sesion")
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean?  @default(false)
  fechaCreacion DateTime? @default(now()) @db.Timestamp(6)
  fechaLectura  DateTime? @db.Timestamp(6)
  eliminada     Boolean?  @default(false)
  archivada     Boolean?  @default(false)
  usuarioId     Int
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notificacion_usuario_id_fkey")

  @@map("notificacion")
}

model CambioEmail {
  id            Int       @id @default(autoincrement())
  email_nuevo   String
  token         String    @unique
  expira_en     DateTime  @db.Timestamp(6)
  creado_en     DateTime? @default(now()) @db.Timestamp(6)
  completado_en DateTime? @db.Timestamp(6)
  usuario_id    Int
  usuario       Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("cambio_email")
}

model Perfil {
  id              Int     @id @default(autoincrement())
  nombre_completo String
  datos           Json?
  usuario_id      Int     @unique
  usuario         Usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("perfil")
}

model Inmueble {
  id                  Int                   @id @default(autoincrement())
  titulo              String
  tipoAccion          TipoAccion            @map("tipo_accion")
  categoria           Categoria?            @map("categoria")
  precio              Decimal               @db.Decimal(12, 2)
  superficieM2        Decimal?              @map("superficie_m2") @db.Decimal(10, 2)
  nroCuartos          Int?                  @map("nro_cuartos")
  nroBanos            Int?                  @map("nro_banos")
  descripcion         String?
  estado              EstadoInmueble?       @default(ACTIVO) @map("estado")
  fechaPublicacion    DateTime?             @default(now()) @map("fecha_publicacion") @db.Timestamp(6)
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime?             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  propietarioId       Int                   @map("propietario_id")
  detalle_comparacion detalle_comparacion[]
  favorito            favorito[]
  propietario         Usuario               @relation(fields: [propietarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inmueble_etiqueta   InmuebleEtiqueta[]
  marcador_mapa       MarcadorMapa[]
  propiedad_vista     propiedad_vista[]
  publicaciones       Publicacion[]
  ubicacion           UbicacionInmueble?

  @@index([propietarioId], map: "idx_inmueble_propietario")
  @@map("inmueble")
}

model UbicacionInmueble {
  id                 Int                @id @default(autoincrement())
  latitud            Decimal            @db.Decimal(10, 7)
  longitud           Decimal            @db.Decimal(10, 7)
  direccion          String?
  inmuebleId         Int                @unique @map("inmueble_id")
  ubicacionMaestraId Int?               @map("ubicacion_maestra_id")
  ciudad             String?
  zona               String?
  marcadores         MarcadorMapa[]
  inmueble           Inmueble           @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion_maestra  ubicacion_maestra? @relation(fields: [ubicacionMaestraId], references: [id])

  @@map("ubicacion_inmueble")
}

model Etiqueta {
  id        Int                @id @default(autoincrement())
  nombre    String             @unique
  inmuebles InmuebleEtiqueta[]

  @@map("etiqueta")
}

model InmuebleEtiqueta {
  inmuebleId Int
  etiquetaId Int
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)
  inmueble   Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@id([inmuebleId, etiquetaId])
  @@map("inmueble_etiqueta")
}

model Publicacion {
  id               Int               @id @default(autoincrement())
  titulo           String
  descripcion      String?
  estado           EstadoPublicacion @default(ACTIVA) @map("estado")
  fechaPublicacion DateTime          @default(now()) @map("fecha_publicacion")
  usuarioId        Int               @map("usuario_id")
  inmuebleId       Int               @map("inmueble_id")
  multimedia       Multimedia[]
  inmueble         Inmueble          @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario          Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("publicacion")
}

model Multimedia {
  id            Int            @id @default(autoincrement())
  url           String
  tipo          TipoMultimedia
  pesoMb        Decimal?       @map("peso_mb") @db.Decimal(8, 2)
  publicacionId Int            @map("publicacion_id")
  publicacion   Publicacion    @relation(fields: [publicacionId], references: [id], onDelete: Cascade)

  @@map("multimedia")
}

model MarcadorMapa {
  id            Int               @id @default(autoincrement())
  tipo          TipoMarcador
  esVisible     Boolean           @default(true)
  nivelZ        Int?
  inmuebleId    Int
  ubicacionId   Int
  grupos        DetalleGrupo[]
  interacciones InteraccionMapa[]
  inmueble      Inmueble          @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  ubicacion     UbicacionInmueble @relation(fields: [ubicacionId], references: [id], onDelete: Cascade)

  @@map("marcador_mapa")
}

model GrupoMarcadores {
  id                Int            @id @default(autoincrement())
  latitudCentro     Decimal        @db.Decimal(10, 7)
  longitudCentro    Decimal        @db.Decimal(10, 7)
  cantidadInmuebles Int
  nivelColor        String?
  nivelZoom         Int
  radioKm           Decimal?       @db.Decimal(10, 2)
  actualizadoEn     DateTime       @updatedAt
  marcadores        DetalleGrupo[]

  @@map("grupo_marcadores")
}

model DetalleGrupo {
  grupoId    Int
  marcadorId Int
  grupo      GrupoMarcadores @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  marcador   MarcadorMapa    @relation(fields: [marcadorId], references: [id], onDelete: Cascade)

  @@id([grupoId, marcadorId])
  @@map("detalle_grupo")
}

model SesionMapa {
  id              Int               @id @default(autoincrement())
  token           String            @unique
  limiteNorte     Decimal?          @db.Decimal(10, 7)
  limiteSur       Decimal?          @db.Decimal(10, 7)
  limiteEste      Decimal?          @db.Decimal(10, 7)
  limiteOeste     Decimal?          @db.Decimal(10, 7)
  nivelZoom       Int
  latitudCentro   Decimal?          @db.Decimal(10, 7)
  longitudCentro  Decimal?          @db.Decimal(10, 7)
  iniciadoEn      DateTime          @default(now())
  ultimaActividad DateTime          @updatedAt
  interacciones   InteraccionMapa[]

  @@map("sesion_mapa")
}

model InteraccionMapa {
  id              Int             @id @default(autoincrement())
  tipo            TipoInteraccion
  latitudMomento  Decimal?        @db.Decimal(10, 7)
  longitudMomento Decimal?        @db.Decimal(10, 7)
  zoomMomento     Int?
  ocurrioEn       DateTime        @default(now())
  sesionId        Int
  marcadorId      Int
  marcador        MarcadorMapa    @relation(fields: [marcadorId], references: [id], onDelete: Cascade)
  sesion          SesionMapa      @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@map("interaccion_mapa")
}

model BannerHome {
  id            Int      @id @default(autoincrement())
  urlImagen     String
  orden         Int
  activo        Boolean  @default(true)
  fechaCreacion DateTime @default(now())
  titulo        String?
  subtitulo     String?

  @@map("banner_home")
}

model Visitor {
  id          Int      @id @default(autoincrement())
  ip          String
  metaData    Json?
  fechaVisita DateTime @default(now())
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("visitor")
}

model public_Telefono {
  id         Int     @id @default(autoincrement())
  numero     String
  usuarioId  Int
  codigoPais String
  principal  Boolean

  @@map("Telefono")
}

model ubicacion_maestra {
  id                 Int                 @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal             @db.Decimal(10, 7)
  longitud           Decimal             @db.Decimal(10, 7)
  popularidad        Int                 @default(0)
  ubicacion_inmueble UbicacionInmueble[]

  @@index([nombre])
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement()) @db.SmallInt
  id_usuario       Int?              @db.SmallInt
  id_suscripcion   Int?              @db.SmallInt
  id_transaccion   Int?              @db.SmallInt
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha_evento")
  @@index([id_transaccion], map: "idx_bitacora_transaccion_id")
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String?                 @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal?                @db.Decimal(10, 2)
  duracion_plan_dias     Int?
  nro_publicaciones_plan Int?
  imagen_gr_url          String?                 @db.VarChar(255)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                Usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario_id")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                Usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ZonaPredefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  @@map("zona_predefinida")
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO

  @@map("genero")
}

enum TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO

  @@map("tipo_accion")
}

enum EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO

  @@map("estado_inmueble")
}

enum EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA

  @@map("estado_publicacion")
}

enum Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA

  @@map("categoria")
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum TipoMultimedia {
  IMAGEN
  VIDEO

  @@map("tipo_multimedia")
}

enum TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER

  @@map("tipo_marcador")
}

enum TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG

  @@map("tipo_interaccion")
}
