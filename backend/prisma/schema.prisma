  id                                   Int      @id @default(autoincrement())
  codigoPais                           String
  numero                               String
  principal                            Boolean? @default(false)
  usuarioId                            Int
  codigo_pais                          String?
  usuario_id                           Int?
  usuario_telefono_usuarioIdTousuario  usuario  @relation("telefono_usuarioIdTousuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario_telefono_usuario_idTousuario usuario? @relation("telefono_usuario_idTousuario", fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "telefono_usuario_fk")

  @@index([usuario_id], map: "idx_telefono_usuario")
}

