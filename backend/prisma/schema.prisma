generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model amenidad {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique @db.VarChar(255)
  inmueble_amenidad inmueble_amenidad[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model audit_log {
  id          Int       @default(autoincrement())
  query       String?
  executed_at DateTime? @default(now()) @db.Timestamp(6)

  @@ignore
}

model autenticacion_social {
  id                   Int       @id @default(autoincrement())
  usuarioId            Int
  proveedor            String    @db.VarChar(30)
  correoProveedor      String?   @db.VarChar(100)
  idExterno            String    @db.VarChar(150)
  vinculadoEn          DateTime? @default(now()) @db.Timestamp(6)
  activo               Boolean?  @default(true)
  token_acceso_cifrado String?
  token_expira_en      DateTime? @db.Timestamptz(6)
  ultimo_uso_en        DateTime? @db.Timestamptz(6)
  usuario              usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([proveedor, idExterno], map: "autenticacion_social_proveedor_idexterno_key")
  @@unique([usuarioId, proveedor], map: "autenticacion_social_usuario_proveedor_key")
}

model banner_home {
  id             Int       @id @default(autoincrement())
  url_imagen     String
  orden          Int
  activo         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  titulo         String?
  subtitulo      String?
}

model barrio {
  id                 Int                  @id @default(autoincrement())
  nombre             String               @db.VarChar(255)
  zona_id            Int
  zona_geografica    zona_geografica      @relation(fields: [zona_id], references: [id], onUpdate: NoAction, map: "barrio_zona_fk")
  ubicacion_inmueble ubicacion_inmueble[]

  @@unique([nombre, zona_id], map: "barrio_nombre_zona_unique")
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha")
}

model blog {
  id                Int            @id @default(autoincrement())
  titulo            String
  contenido         String
  imagen            String?
  estado            estado_blog
  eliminado         Boolean?       @default(false)
  fecha_creacion    DateTime?      @default(now()) @db.Timestamp(6)
  fecha_publicacion DateTime?      @db.Timestamp(6)
  usuario_id        Int
  categoria_id      Int
  categoria_blog    categoria_blog @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_categoria_fk")
  usuario           usuario        @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_usuario_fk")
  blog_rechazo      blog_rechazo[]
  comentario        comentario[]
  notificacion      notificacion[]

  @@index([estado])
  @@index([usuario_id], map: "blog_usuario_idx")
}

model blog_rechazo {
  id         Int       @id @default(autoincrement())
  comentario String
  fecha      DateTime? @default(now()) @db.Timestamp(6)
  blog_id    Int
  blog       blog      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_rechazo_blog_fk")
}

model cambio_email {
  id            Int       @id @default(autoincrement())
  email_nuevo   String
  token         String    @unique
  expira_en     DateTime  @db.Timestamp(6)
  creado_en     DateTime? @default(now()) @db.Timestamp(6)
  completado_en DateTime? @db.Timestamp(6)
  usuario_id    Int
  usuario       usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model categoria_blog {
  id     Int    @id @default(autoincrement())
  nombre String @unique @db.VarChar(100)
  blog   blog[]
}

model ciudad {
  id            Int             @id @default(autoincrement())
  nombre        String          @unique
  slug          String          @unique
  descripcion   String?
  popularidad   Int?            @default(0)
  ciudad_imagen ciudad_imagen[]
}

model ciudad_imagen {
  id       Int    @id @default(autoincrement())
  ciudadid Int
  url      String
  orden    Int?   @default(0)
  ciudad   ciudad @relation(fields: [ciudadid], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model codigo_2fa {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  codigoHash String    @db.VarChar(255)
  creadoEn   DateTime? @default(now()) @db.Timestamp(6)
  expiraEn   DateTime  @db.Timestamp(6)
  usadoEn    DateTime? @db.Timestamp(6)
  intentos   Int?      @default(0)
  activo     Boolean?  @default(true)
  usuario    usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "codigo_2fa_usuario_fecha_idx")
}

model comentario {
  id                  Int               @id @default(autoincrement())
  contenido           String
  fecha_creacion      DateTime?         @default(now()) @db.Timestamp(6)
  usuario_id          Int
  blog_id             Int
  comentario_padre_id Int?
  blog                blog              @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_blog_fk")
  comentario          comentario?       @relation("comentarioTocomentario", fields: [comentario_padre_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_padre_fk")
  other_comentario    comentario[]      @relation("comentarioTocomentario")
  usuario             usuario           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_usuario_fk")
  comentario_like     comentario_like[]

  @@index([blog_id], map: "comentario_blog_idx")
}

model comentario_like {
  id            Int        @id @default(autoincrement())
  usuario_id    Int
  comentario_id Int
  comentario    comentario @relation(fields: [comentario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_comentario_fk")
  usuario       usuario    @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_usuario_fk")

  @@unique([usuario_id, comentario_id], map: "comentario_like_unique")
}

model comparacion {
  id                  Int                   @id @default(autoincrement())
  nombre              String?               @db.VarChar(100)
  creadoEn            DateTime              @default(now())
  usuarioId           Int
  activo              Boolean               @default(true)
  usuario             usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  detalle_comparacion detalle_comparacion[]
}

model cupon {
  id              Int             @id @default(autoincrement())
  codigo          String          @unique @db.VarChar(50)
  descripcion     String?
  tipo_descuento  String          @default("PORCENTAJE") @db.VarChar(10)
  valor_descuento Decimal         @db.Decimal(10, 2)
  max_usos        Int             @default(1)
  usos_actuales   Int             @default(0)
  fecha_inicio    DateTime        @default(now()) @db.Timestamptz(6)
  fecha_fin       DateTime        @db.Timestamptz(6)
  activo          Boolean?        @default(true)
  fecha_creacion  DateTime?       @default(now()) @db.Timestamptz(6)
  transacciones   transacciones[]
}

model departamento {
  id                                             Int         @id @default(autoincrement())
  nombre                                         String      @unique @db.VarChar(255)
  provincia_provincia_departamentoTodepartamento provincia[] @relation("provincia_departamentoTodepartamento")
}

model detalle_comparacion {
  id            Int         @id @default(autoincrement())
  comparacionId Int
  inmuebleId    Int
  orden         Int         @default(0)
  comparacion   comparacion @relation(fields: [comparacionId], references: [id], onDelete: Cascade)
  inmueble      inmueble    @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([comparacionId, inmuebleId])
}

model detalle_grupo {
  grupo_id         Int
  marcador_id      Int
  grupo_marcadores grupo_marcadores @relation(fields: [grupo_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  marcador_mapa    marcador_mapa    @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([grupo_id, marcador_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model entrenamiento_ml {
  id                Int      @id @default(autoincrement())
  usuario_id        Int
  inmueble_id       Int
  tipo_evento       String   @default("CLICK") @db.VarChar(20)
  score_real        Float    @default(0) @db.Real
  retroalimentacion Int?     @db.SmallInt
  features          Json?
  fecha_evento      DateTime @default(now()) @db.Timestamp(6)
  usado_en_modelo   Boolean  @default(false)
  version_modelo    String?  @db.VarChar(20)
  inmueble          inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario           usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([fecha_evento(sort: Desc)], map: "idx_ml_fecha")
  @@index([tipo_evento], map: "idx_ml_tipo_evento")
  @@index([usuario_id, usado_en_modelo], map: "idx_ml_usuario_usado")
}

model etiqueta {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique
  inmueble_etiqueta inmueble_etiqueta[]
}

model favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  agregadoEn DateTime @default(now())
  inmueble   inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario    usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
}

model grupo_marcadores {
  id                 Int             @id @default(autoincrement())
  latitud_centro     Decimal         @db.Decimal(10, 7)
  longitud_centro    Decimal         @db.Decimal(10, 7)
  cantidad_inmuebles Int
  nivel_color        String?
  nivel_zoom         Int
  radio_km           Decimal?        @db.Decimal(10, 2)
  actualizado_en     DateTime?       @default(now()) @db.Timestamp(6)
  detalle_grupo      detalle_grupo[]
}

model historial_busqueda {
  id        Int       @id @default(autoincrement())
  usuarioid Int
  termino   String
  creadoen  DateTime? @default(now()) @db.Timestamp(6)
  usuario   usuario   @relation(fields: [usuarioid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "historial_usuario_fkey")
}

model historial_password {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  passwordHash String    @db.VarChar(255)
  creadoEn     DateTime? @default(now()) @db.Timestamp(6)
  usuario      usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "historial_password_usuario_fecha_idx")
}

model inmueble {
  id                  Int                   @id @default(autoincrement())
  titulo              String
  tipo_accion         tipo_accion
  categoria           categoria?
  precio              Decimal               @db.Decimal(12, 2)
  superficie_m2       Decimal?              @db.Decimal(10, 2)
  nro_cuartos         Int?
  nro_banos           Int?
  descripcion         String?
  estado              estado_inmueble?      @default(ACTIVO)
  fecha_publicacion   DateTime?             @default(now()) @db.Timestamp(6)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  updated_at          DateTime?             @default(now()) @db.Timestamp(6)
  propietario_id      Int
  banoCompartido      Boolean?              @default(false)
  precio_anterior     Decimal?              @db.Decimal(12, 2)
  fecha_reduccion     DateTime?             @db.Timestamp(6)
  detalle_comparacion detalle_comparacion[]
  entrenamiento_ml    entrenamiento_ml[]
  favorito            favorito[]
  usuario             usuario               @relation(fields: [propietario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_propietario_fk")
  inmueble_amenidad   inmueble_amenidad[]
  inmueble_etiqueta   inmueble_etiqueta[]
  marcador_mapa       marcador_mapa[]
  propiedad_vista     propiedad_vista[]
  publicacion         publicacion[]
  ubicacion_inmueble  ubicacion_inmueble?

  @@index([estado], map: "idx_inmueble_estado")
  @@index([propietario_id], map: "idx_inmueble_propietario")
  @@index([tipo_accion], map: "idx_inmueble_tipo_accion")
}

model inmueble_amenidad {
  inmueble_id Int
  amenidad_id Int
  amenidad    amenidad @relation(fields: [amenidad_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_amenidad_fk")
  inmueble    inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_inmueble_fk")

  @@id([inmueble_id, amenidad_id])
}

model inmueble_etiqueta {
  inmueble_id Int
  etiqueta_id Int
  etiqueta    etiqueta @relation(fields: [etiqueta_id], references: [id], onUpdate: NoAction, map: "inmueble_etiqueta_etiqueta_fk")
  inmueble    inmueble @relation(fields: [inmueble_id], references: [id], onUpdate: NoAction, map: "inmueble_etiqueta_inmueble_fk")

  @@id([inmueble_id, etiqueta_id])
}

model interaccion_mapa {
  id               Int              @id @default(autoincrement())
  tipo             tipo_interaccion
  latitud_momento  Decimal?         @db.Decimal(10, 7)
  longitud_momento Decimal?         @db.Decimal(10, 7)
  zoom_momento     Int?
  ocurrio_en       DateTime?        @default(now()) @db.Timestamp(6)
  sesion_id        Int?
  marcador_id      Int?
  marcador_mapa    marcador_mapa?   @relation(fields: [marcador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sesion_mapa      sesion_mapa?     @relation(fields: [sesion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model magic_link {
  id                Int       @id @default(autoincrement())
  usuario_id        Int
  token_hash        String    @unique @db.VarChar(64)
  correo            String    @db.VarChar(255)
  expira_en         DateTime  @db.Timestamptz(6)
  usado_en          DateTime? @db.Timestamptz(6)
  activo            Boolean?  @default(true)
  creado_en         DateTime? @default(now()) @db.Timestamptz(6)
  intentos_reenvio  Int?      @default(0)
  ultimo_reenvio_en DateTime? @db.Timestamptz(6)
  invalidado_en     DateTime? @db.Timestamptz(6)
  usuario           usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_magic_link_token_hash")
  @@index([usuario_id], map: "idx_magic_link_usuario")
  @@index([usuario_id, activo], map: "idx_magic_link_usuario_activo")
}

model marcador_mapa {
  id                 Int                @id @default(autoincrement())
  tipo               tipo_marcador
  es_visible         Boolean?           @default(true)
  nivel_z            Int?
  inmueble_id        Int
  ubicacion_id       Int
  detalle_grupo      detalle_grupo[]
  interaccion_mapa   interaccion_mapa[]
  inmueble           inmueble           @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ubicacion_inmueble ubicacion_inmueble @relation(fields: [ubicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model modelo_version {
  id           Int      @id @default(autoincrement())
  version      String   @unique @db.VarChar(20)
  archivo_path String   @db.VarChar(255)
  algoritmo    String   @db.VarChar(50)
  precision    Float?   @db.Real
  recall       Float?   @db.Real
  datos_usados Int?
  activo       Boolean  @unique(map: "idx_modelo_activo", where: raw("(activo = true)")) @default(false)
  entrenado_en DateTime @default(now()) @db.Timestamp(6)
  notas        String?
}

model multimedia {
  id             Int             @id @default(autoincrement())
  url            String
  tipo           tipo_multimedia
  peso_mb        Decimal?        @db.Decimal(8, 2)
  publicacion_id Int
  publicacion    publicacion     @relation(fields: [publicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "multimedia_publicacion_fk")

  @@index([publicacion_id], map: "idx_multimedia_publicacion")
}

model municipio {
  id                                                   Int               @id @default(autoincrement())
  nombre                                               String            @db.VarChar(255)
  provincia                                            Int?
  provincia_municipio_provinciaToprovincia             provincia?        @relation("municipio_provinciaToprovincia", fields: [provincia], references: [id], onDelete: Restrict, onUpdate: NoAction)
  zona_geografica_zona_geografica_municipioTomunicipio zona_geografica[] @relation("zona_geografica_municipioTomunicipio")

  @@unique([nombre, provincia], map: "municipio_nombre_provincia_unique")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model notificacion {
  id            Int       @id @default(autoincrement())
  titulo        String
  mensaje       String
  leida         Boolean   @default(false)
  fechaCreacion DateTime? @default(now()) @db.Timestamp(6)
  fechaLectura  DateTime? @db.Timestamp(6)
  eliminada     Boolean   @default(false)
  archivada     Boolean   @default(false)
  usuarioId     Int
  tipo          String    @default("GENERAL") @db.VarChar(30)
  blog_id       Int?
  blog          blog?     @relation(fields: [blog_id], references: [id], onUpdate: NoAction, map: "notificacion_blog_fk")
  usuario       usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "notificacion_usuario_id_fkey")

  @@index([blog_id], map: "idx_notificacion_blog")
  @@index([usuarioId, leida], map: "idx_notificacion_usuario_leida")
}

model parametros_personalizados {
  id                    Int                     @id @default(autoincrement())
  nombre                String?                 @db.VarChar(255)
  descripcion           String?
  creado_en             DateTime?               @default(now()) @db.Timestamptz(6)
  publicacion_parametro publicacion_parametro[]
}

model perfil {
  id              Int     @id @default(autoincrement())
  nombre_completo String
  datos           Json?
  usuario_id      Int     @unique
  usuario         usuario @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String?                 @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal?                @db.Decimal(10, 2)
  duracion_plan_dias     Int?
  nro_publicaciones_plan Int?
  imagen_gr_url          String?                 @db.VarChar(255)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model propiedad_vista {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  inmuebleId  Int
  vistaEn     DateTime @default(now())
  veces_visto Int?     @default(1) @db.SmallInt
  activo      Boolean? @default(true)
  inmueble    inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario     usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
  @@index([usuarioId, vistaEn])
}

model provincia {
  id                                                Int          @id @default(autoincrement())
  nombre                                            String       @db.VarChar(255)
  departamento                                      Int
  municipio_municipio_provinciaToprovincia          municipio[]  @relation("municipio_provinciaToprovincia")
  departamento_provincia_departamentoTodepartamento departamento @relation("provincia_departamentoTodepartamento", fields: [departamento], references: [id], onUpdate: NoAction)

  @@unique([nombre, departamento], map: "provincia_nombre_departamento_unique")
}

model publicacion {
  id                    Int                     @id @default(autoincrement())
  titulo                String
  descripcion           String?
  estado                estado_publicacion?     @default(ACTIVA)
  fecha_publicacion     DateTime?               @default(now()) @db.Timestamp(6)
  usuario_id            Int
  inmueble_id           Int
  payment_intent_id     String?
  promoted              Boolean                 @default(false)
  promoted_at           DateTime?               @db.Timestamp(6)
  promoted_expires_at   DateTime?               @db.Timestamp(6)
  multimedia            multimedia[]
  inmueble              inmueble                @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "publicacion_inmueble_fk")
  usuario               usuario                 @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "publicacion_usuario_fk")
  publicacion_parametro publicacion_parametro[]
  publicacion_tag       publicacion_tag[]

  @@index([estado], map: "idx_publicacion_estado")
  @@index([inmueble_id], map: "idx_publicacion_inmueble")
  @@index([promoted], map: "idx_publicacion_promoted")
  @@index([usuario_id], map: "idx_publicacion_usuario")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model publicacion_compartido {
  id             Int      @id @default(autoincrement())
  publicacion_id Int
  usuario_id     Int
  medio          String?  @db.VarChar(50)
  creado_en      DateTime @default(now()) @db.Timestamp(6)

  @@index([publicacion_id], map: "idx_publicacion_compartido_publicacion")
