generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model amenidad {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique @db.VarChar(255)
  inmueble_amenidad inmueble_amenidad[]
}

model Telefono {
  id                                   Int      @id @default(autoincrement())
  codigoPais                           String
  numero                               String
  principal                            Boolean? @default(false)
  usuarioId                            Int
  codigo_pais                          String?
  usuario_id                           Int?
  usuario                              Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario_telefono_usuario_idTousuario Usuario? @relation("telefono_usuario_idTousuario", fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "telefono_usuario_fk")

  @@index([usuario_id], map: "idx_telefono_usuario")
  @@map("telefono")
}

model Sesion {
  id              Int       @id @default(autoincrement())
  token           String    @unique
  fechaInicio     DateTime? @default(now()) @db.Timestamp(6)
  fechaExpiracion DateTime  @db.Timestamp(6)
  estado          Boolean?  @default(true)
  usuarioId       Int
  proveedor       String    @db.VarChar(30)
  correoProveedor String?   @db.VarChar(100)
  idExterno       String    @db.VarChar(150)
  vinculadoEn     DateTime? @default(now()) @db.Timestamp(6)
  activo          Boolean?  @default(true)
  usuario         usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("interaccion_mapa")
}

model BannerHome {
  id             Int       @id @default(autoincrement())
  url_imagen     String
  orden          Int
  activo         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  titulo         String?
  subtitulo      String?

  @@map("banner_home")
}

model Visitor {
  id           Int       @id @default(autoincrement())
  ip           String
  meta_data    Json?
  fecha_visita DateTime? @default(now()) @db.Timestamp(6)
  usuario_id   Int?
  usuario      Usuario?  @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("visitor")
}

model ubicacion_maestra {
  id                 Int                 @id @default(autoincrement())
  departamento       String
  provincia          String?
  municipio          String?
  nombre             String
  latitud            Decimal             @db.Decimal(10, 7)
  longitud           Decimal             @db.Decimal(10, 7)
  popularidad        Int?                @default(0)
  ubicacion_inmueble UbicacionInmueble[]

  @@index([nombre], map: "idx_ubicacion_nombre")
}

model bitacora_pagos {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  evento           String            @db.VarChar(100)
  mensaje          String?
  fecha_evento     DateTime?         @default(now()) @db.Timestamp(6)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([fecha_evento], map: "idx_bitacora_fecha")
}

model plan_suscripcion {
  id                     Int                     @id @default(autoincrement())
  nombre_plan            String?                 @db.VarChar(50)
  descripcion_plan       String?
  precio_plan            Decimal?                @db.Decimal(10, 2)
  duracion_plan_dias     Int?
  nro_publicaciones_plan Int?
  imagen_gr_url          String?                 @db.VarChar(255)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  transacciones          transacciones[]
}

model suscripciones_activas {
  id               Int               @id @default(autoincrement())
  id_usuario       Int?
  id_suscripcion   Int?
  id_transaccion   Int?
  fecha_inicio     DateTime          @db.Timestamp(6)
  fecha_fin        DateTime          @db.Timestamp(6)
  estado           String?           @default("INACTIVA") @db.VarChar(20)
  plan_suscripcion plan_suscripcion? @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones    transacciones?    @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario          Usuario?          @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transacciones {
  id                     Int                     @id @default(autoincrement())
  id_usuario             Int
  id_suscripcion         Int
  subtotal               Decimal                 @db.Decimal(10, 2)
  iva_porcentaje         Decimal                 @db.Decimal(5, 2)
  iva_monto              Decimal                 @db.Decimal(10, 2)
  total                  Decimal                 @db.Decimal(10, 2)
  metodo_pago            String?                 @default("QR_BANCARIO") @db.VarChar(30)
  fecha_intento          DateTime?               @default(now()) @db.Timestamp(6)
  fecha_completado       DateTime?               @db.Timestamp(6)
  estado                 String?                 @default("PENDIENTE") @db.VarChar(20)
  verificacion_requerida Boolean?                @default(true)
  tiempo_activacion      DateTime?               @db.Timestamp(6)
  cupon_id               Int?
  monto_descuento        Decimal?                @default(0) @db.Decimal(10, 2)
  bitacora_pagos         bitacora_pagos[]
  suscripciones_activas  suscripciones_activas[]
  cupon                  cupon?                  @relation(fields: [cupon_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plan_suscripcion       plan_suscripcion        @relation(fields: [id_suscripcion], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usuario                Usuario                 @relation(fields: [id_usuario], references: [id], onDelete: NoAction, onUpdate: NoAction)
  verificacion_pago      verificacion_pago[]

  @@index([estado], map: "idx_transacciones_estado")
  @@index([id_usuario], map: "idx_transacciones_usuario")
}

model verificacion_pago {
  id                     Int            @id @default(autoincrement())
  id_transaccion         Int?
  id_admin               Int
  fecha_verificacion     DateTime?      @default(now()) @db.Timestamp(6)
  resultado_verificacion String?        @default("VERIFICADO") @db.VarChar(20)
  usuario                Usuario        @relation(fields: [id_admin], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transacciones          transacciones? @relation(fields: [id_transaccion], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ZonaPredefinida {
  id          Int      @id @default(autoincrement())
  nombre      String
  coordenadas Json
  color       String   @default("#ea580c")
  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  @@map("zona_predefinida")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model audit_log {
  id          Int       @default(autoincrement())
  query       String?
  executed_at DateTime? @default(now()) @db.Timestamp(6)

  @@ignore
}

model autenticacion_social {
  id              Int       @id @default(autoincrement())
  usuarioId       Int
  proveedor       String    @db.VarChar(30)
  correoProveedor String?   @db.VarChar(100)
  idExterno       String    @db.VarChar(150)
  vinculadoEn     DateTime? @default(now()) @db.Timestamp(6)
  activo          Boolean?  @default(true)
  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([proveedor, idExterno], map: "autenticacion_social_proveedor_idexterno_key")
  @@unique([usuarioId, proveedor], map: "autenticacion_social_usuario_proveedor_key")
}

model codigo_2fa {
  id         Int       @id @default(autoincrement())
  usuarioId  Int
  codigoHash String    @db.VarChar(255)
  creadoEn   DateTime? @default(now()) @db.Timestamp(6)
  expiraEn   DateTime  @db.Timestamp(6)
  usadoEn    DateTime? @db.Timestamp(6)
  intentos   Int?      @default(0)
  activo     Boolean?  @default(true)
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "codigo_2fa_usuario_fecha_idx")
}

model comparacion {
  id                  Int                   @id @default(autoincrement())
  nombre              String?               @db.VarChar(100)
  creadoEn            DateTime              @default(now())
  usuarioId           Int
  usuario             Usuario               @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  detalle_comparacion detalle_comparacion[]
}

model detalle_comparacion {
  id            Int         @id @default(autoincrement())
  comparacionId Int
  inmuebleId    Int
  orden         Int         @default(0)
  comparacion   comparacion @relation(fields: [comparacionId], references: [id], onDelete: Cascade)
  inmueble      Inmueble    @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)

  @@unique([comparacionId, inmuebleId])
}

model favorito {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  inmuebleId Int
  agregadoEn DateTime @default(now())
  inmueble   Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
}

model historial_password {
  id           Int       @id @default(autoincrement())
  usuarioId    Int
  passwordHash String    @db.VarChar(255)
  creadoEn     DateTime? @default(now()) @db.Timestamp(6)
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "historial_password_usuario_fecha_idx")
}

model propiedad_vista {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  inmuebleId  Int
  vistaEn     DateTime @default(now())
  veces_visto Int?     @default(1) @db.SmallInt
  inmueble    Inmueble @relation(fields: [inmuebleId], references: [id], onDelete: Cascade)
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, inmuebleId])
  @@index([usuarioId, vistaEn])
}

model recuperacion_password {
  id        Int       @id @default(autoincrement())
  usuarioId Int
  token     String    @unique @db.VarChar(255)
  expiraEn  DateTime  @db.Timestamp(6)
  creadoEn  DateTime? @default(now()) @db.Timestamp(6)
  usadoEn   DateTime? @db.Timestamp(6)
  intentos  Int?      @default(0)
  activo    Boolean?  @default(true)
  usuario   Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, creadoEn], map: "recuperacion_password_usuario_fecha_idx")
}

model zona_usuario {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(100)
  descripcion   String?
  geometria     Json
  area          Decimal? @db.Decimal(12, 4)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime
  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

model ciudad {
  id            Int             @id @default(autoincrement())
  nombre        String          @unique
  slug          String          @unique
  descripcion   String?
  popularidad   Int?            @default(0)
  ciudad_imagen ciudad_imagen[]
}

model ciudad_imagen {
  id       Int    @id @default(autoincrement())
  ciudadid Int
  url      String
  orden    Int?   @default(0)
  ciudad   ciudad @relation(fields: [ciudadid], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model cupon {
  id              Int             @id @default(autoincrement())
  codigo          String          @unique @db.VarChar(50)
  descripcion     String?
  tipo_descuento  String          @default("PORCENTAJE") @db.VarChar(10)
  valor_descuento Decimal         @db.Decimal(10, 2)
  max_usos        Int             @default(1)
  usos_actuales   Int             @default(0)
  fecha_inicio    DateTime        @default(now()) @db.Timestamptz(6)
  fecha_fin       DateTime        @db.Timestamptz(6)
  activo          Boolean?        @default(true)
  fecha_creacion  DateTime?       @default(now()) @db.Timestamptz(6)
  transacciones   transacciones[]
}

model historial_busqueda {
  id        Int       @id @default(autoincrement())
  usuarioid Int
  termino   String
  creadoen  DateTime? @default(now()) @db.Timestamp(6)
  usuario   Usuario   @relation(fields: [usuarioid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "historial_usuario_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model parametros_personalizados {
  id                    Int                     @id @default(autoincrement())
  nombre                String?                 @db.VarChar(255)
  descripcion           String?
  creado_en             DateTime?               @default(now()) @db.Timestamptz(6)
  publicacion_parametro publicacion_parametro[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model publicacion_parametro {
  id                        Int                        @id @default(autoincrement())
  publicacion_id            Int?
  parametro_id              Int?
  valor                     String?
  creado_en                 DateTime?                  @default(now()) @db.Timestamptz(6)
  parametros_personalizados parametros_personalizados? @relation(fields: [parametro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "pub_param_parametro_fk")
  publicacion               Publicacion?               @relation(fields: [publicacion_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "pub_param_publicacion_fk")

  @@unique([publicacion_id, parametro_id], map: "uq_publicacion_parametro")
  @@index([parametro_id], map: "idx_pub_param_parametro")
  @@index([publicacion_id], map: "idx_pub_param_publicacion")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model spatial_ref_sys {
  srid      Int     @id
  auth_name String? @db.VarChar(256)
  auth_srid Int?
  srtext    String? @db.VarChar(2048)
  proj4text String? @db.VarChar(2048)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model amenidad {
  id                Int                 @id @default(autoincrement())
  nombre            String              @unique @db.VarChar(255)
  inmueble_amenidad inmueble_amenidad[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model barrio {
  id                                                      Int                 @id @default(autoincrement())
  nombre                                                  String              @db.VarChar(255)
  zona_id                                                 Int
  zona_geografica                                         Int?
  zona_geografica_barrio_zona_idTozona_geografica         zona_geografica     @relation("barrio_zona_idTozona_geografica", fields: [zona_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "barrio_zona_fk")
  zona_geografica_barrio_zona_geograficaTozona_geografica zona_geografica?    @relation("barrio_zona_geograficaTozona_geografica", fields: [zona_geografica], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ubicacion_inmueble                                      UbicacionInmueble[]

  @@unique([nombre, zona_id], map: "barrio_nombre_zona_unique")
}

model blog {
  id                Int            @id @default(autoincrement())
  titulo            String
  contenido         String
  imagen            String?
  estado            estado_blog
  eliminado         Boolean?       @default(false)
  fecha_creacion    DateTime?      @default(now()) @db.Timestamp(6)
  fecha_publicacion DateTime?      @db.Timestamp(6)
  usuario_id        Int
  categoria_id      Int
  categoria_blog    categoria_blog @relation(fields: [categoria_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_categoria_fk")
  usuario           Usuario        @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_usuario_fk")
  blog_rechazo      blog_rechazo[]
  comentario        comentario[]

  @@index([estado])
  @@index([usuario_id], map: "blog_usuario_idx")
}

model blog_rechazo {
  id         Int       @id @default(autoincrement())
  comentario String
  fecha      DateTime? @default(now()) @db.Timestamp(6)
  blog_id    Int
  blog       blog      @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_rechazo_blog_fk")
}

model categoria_blog {
  id     Int    @id @default(autoincrement())
  nombre String @unique @db.VarChar(100)
  blog   blog[]
}

model comentario {
  id                  Int               @id @default(autoincrement())
  contenido           String
  fecha_creacion      DateTime?         @default(now()) @db.Timestamp(6)
  usuario_id          Int
  blog_id             Int
  comentario_padre_id Int?
  blog                blog              @relation(fields: [blog_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_blog_fk")
  comentario          comentario?       @relation("comentarioTocomentario", fields: [comentario_padre_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_padre_fk")
  other_comentario    comentario[]      @relation("comentarioTocomentario")
  usuario             Usuario           @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_usuario_fk")
  comentario_like     comentario_like[]

  @@index([blog_id], map: "comentario_blog_idx")
}

model comentario_like {
  id            Int        @id @default(autoincrement())
  usuario_id    Int
  comentario_id Int
  comentario    comentario @relation(fields: [comentario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_comentario_fk")
  usuario       Usuario    @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "comentario_like_usuario_fk")

  @@unique([usuario_id, comentario_id], map: "comentario_like_unique")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model departamento {
  id                                             Int         @id @default(autoincrement())
  nombre                                         String      @unique @db.VarChar(255)
  provincia_provincia_departamentoTodepartamento provincia[] @relation("provincia_departamentoTodepartamento")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model inmueble_amenidad {
  inmueble_id Int
  amenidad_id Int
  amenidad    amenidad @relation(fields: [amenidad_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_amenidad_fk")
  inmueble    Inmueble @relation(fields: [inmueble_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "inmueble_amenidad_inmueble_fk")

  @@id([inmueble_id, amenidad_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model municipio {
  id                                                   Int               @id @default(autoincrement())
  nombre                                               String            @db.VarChar(255)
  provincia                                            Int
  provincia_id                                         Int?
  provincia_municipio_provinciaToprovincia             provincia         @relation("municipio_provinciaToprovincia", fields: [provincia], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zona_geografica_zona_geografica_municipioTomunicipio zona_geografica[] @relation("zona_geografica_municipioTomunicipio")

  @@unique([nombre, provincia], map: "municipio_nombre_provincia_unique")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model provincia {
  id                                                Int          @id @default(autoincrement())
  nombre                                            String       @db.VarChar(255)
  departamento                                      Int
  departamento_id                                   Int?
  municipio_municipio_provinciaToprovincia          municipio[]  @relation("municipio_provinciaToprovincia")
  departamento_provincia_departamentoTodepartamento departamento @relation("provincia_departamentoTodepartamento", fields: [departamento], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nombre, departamento], map: "provincia_nombre_departamento_unique")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model zona_geografica {
  id                                             Int       @id @default(autoincrement())
  nombre                                         String    @db.VarChar(255)
  municipio                                      Int
  municipio_id                                   Int?
  barrio_barrio_zona_idTozona_geografica         barrio[]  @relation("barrio_zona_idTozona_geografica")
  barrio_barrio_zona_geograficaTozona_geografica barrio[]  @relation("barrio_zona_geograficaTozona_geografica")
  municipio_zona_geografica_municipioTomunicipio municipio @relation("zona_geografica_municipioTomunicipio", fields: [municipio], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([nombre, municipio], map: "zona_geografica_nombre_municipio_unique")
}

enum Genero {
  MASCULINO
  FEMENINO
  OTRO
  PREFIERO_NO_DECIR

  @@map("genero")
}

enum TipoAccion {
  VENTA
  ALQUILER
  ANTICRETO

  @@map("tipo_accion")
}

enum EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO

  @@map("estado_inmueble")
}

enum EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA

  @@map("estado_publicacion")
}

enum Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA

  @@map("categoria")
}

enum RolNombre {
  ADMIN
  PROPIETARIO
  AGENTE
  VISITANTE
}

enum TipoMultimedia {
  IMAGEN
  VIDEO

  @@map("tipo_multimedia")
}

enum TipoMarcador {
  NORMAL
  DESTACADO
  CLUSTER

  @@map("tipo_marcador")
}

enum TipoInteraccion {
  CLICK
  HOVER
  ZOOM
  DRAG

  @@map("tipo_interaccion")
}

enum public_Categoria {
  CASA
  DEPARTAMENTO
  TERRENO
  OFICINA

  @@map("Categoria")
}

enum EstadoBlog {
  BORRADOR
  PENDIENTE
  PUBLICADO
  RECHAZADO
}

enum public_EstadoInmueble {
  ACTIVO
  INACTIVO
  VENDIDO
  ALQUILADO
  RESERVADO

  @@map("EstadoInmueble")
}

enum public_EstadoPublicacion {
  ACTIVA
  PAUSADA
  ELIMINADA

  @@map("EstadoPublicacion")
}

