{
  "name": "social-is-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "bun install",
    "dev:back": "cd backend && bun run dev",
    "dev:front": "cd frontend && bun run dev",
    "dev": "concurrently \"bun run dev:back\" \"bun run dev:front\"",
    "lab:chaos": "cd scripts && sh chaos_devs.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:back": "eslint backend",
    "lint:front": "eslint frontend"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.0",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "tailwind": "^4.0.0"
  }
}